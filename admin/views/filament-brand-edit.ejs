<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AEJaCA Admin — <%= brand ? 'Edytuj markę #' + brand.id : 'Nowa marka' %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            neutral: { 950: '#0a0a0a' }
          }
        }
      }
    }
  </script>
</head>
<body class="bg-neutral-950 min-h-screen text-neutral-100">

  <header class="bg-neutral-900 border-b border-white/10 px-6 py-3 flex items-center justify-between">
    <div class="flex items-center gap-6">
      <span class="text-lg font-bold text-white">AEJaCA <span class="text-amber-400">Admin</span></span>
      <nav class="flex gap-4 text-sm">
        <a href="/dashboard" class="text-neutral-400 hover:text-white transition-colors">Dashboard</a>
        <a href="/analytics" class="text-neutral-400 hover:text-white transition-colors">Analytics</a>
        <a href="/leads" class="text-neutral-400 hover:text-white transition-colors">Leads</a>
        <a href="/subscribers" class="text-neutral-400 hover:text-white transition-colors">Subscribers</a>
        <a href="/conversations" class="text-neutral-400 hover:text-white transition-colors">Chat</a>
        <a href="/orders" class="text-neutral-400 hover:text-white transition-colors">Zamówienia</a>
        <a href="/laser-matrix" class="text-neutral-400 hover:text-white transition-colors">Laser Matrix</a>
        <a href="/gemstone-prices" class="text-neutral-400 hover:text-white transition-colors">Gems</a>
        <a href="/filaments" class="text-white font-medium border-b border-amber-400 pb-0.5">Filamenty<% if (typeof pendingContributions !== 'undefined' && pendingContributions > 0) { %> <span class="text-amber-400">(<%= pendingContributions %>)</span><% } %></a>
      </nav>
    </div>
    <div class="flex items-center gap-3">
      <img src="<%= user.photo %>" class="w-7 h-7 rounded-full" alt="" />
      <span class="text-sm text-neutral-400"><%= user.name %></span>
      <a href="/logout" class="text-xs text-red-400 hover:text-red-300 transition-colors">Logout</a>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-6 py-8">

    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-neutral-500 mb-6">
      <a href="/filaments" class="hover:text-amber-400 transition-colors">&larr; Filamenty</a>
      <span>&rsaquo;</span>
      <a href="/filaments/<%= typeId %>/brands" class="hover:text-amber-400 transition-colors">&larr; Marki<% if (brand && brand.type_name) { %> — <%= brand.type_name %><% } %></a>
      <span>&rsaquo;</span>
      <% if (brand) { %>
        <span class="text-neutral-300">Edytuj markę #<%= brand.id %></span>
      <% } else { %>
        <span class="text-neutral-300">Nowa marka</span>
      <% } %>
    </div>

    <% if (flash === 'created') { %>
    <div class="mb-5 px-4 py-3 bg-emerald-950 border border-emerald-700/50 text-emerald-300 rounded-lg text-sm">
      &#10003; Marka dodana pomyślnie
    </div>
    <% } %>

    <!-- Parent type reference box -->
    <% var parentType = brand || (typeof type !== 'undefined' ? type : null); %>
    <% if (parentType && (parentType.t_nozzle_min || parentType.nozzle_min)) { %>
    <div class="mb-6 px-4 py-3 bg-blue-950/30 border border-blue-800/30 rounded-lg text-xs text-blue-300">
      <strong>Domyślne wartości dla tego typu:</strong>
      Dysza <%= parentType.t_nozzle_min || parentType.nozzle_min || '?' %>–<%= parentType.t_nozzle_max || parentType.nozzle_max || '?' %>°C &nbsp;&middot;&nbsp;
      Łoże <%= parentType.t_bed_min || parentType.bed_min || '?' %>–<%= parentType.t_bed_max || parentType.bed_max || '?' %>°C &nbsp;&middot;&nbsp;
      Prędkość <%= parentType.t_speed_min || parentType.speed_min || '?' %>–<%= parentType.t_speed_max || parentType.speed_max || '?' %> mm/s
      <span class="text-blue-500 ml-2">(zostaw puste, aby używać wartości z typu)</span>
    </div>
    <% } %>

    <form method="POST" action="<%= brand ? '/filaments/brands/' + brand.id + '/update' : '/filaments/' + typeId + '/brands/create' %>" class="space-y-8">

      <!-- Identyfikacja marki -->
      <fieldset class="bg-neutral-900 border border-white/10 rounded-xl p-6">
        <legend class="text-sm font-semibold text-blue-400 uppercase tracking-wider px-2 mb-4">Identyfikacja marki</legend>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Marka / Producent</label>
            <input type="text" name="brand" value="<%= brand ? (brand.brand || '') : '' %>"
              placeholder="np. Bambu Lab, Prusa, Fiberlogy"
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50" />
          </div>

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Nazwa produktu</label>
            <input type="text" name="product_name" value="<%= brand ? (brand.product_name || '') : '' %>"
              placeholder="np. Basic PLA, Prusament PLA"
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50" />
          </div>

          <div class="sm:col-span-2">
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">URL produktu</label>
            <input type="url" name="product_url" value="<%= brand ? (brand.product_url || '') : '' %>"
              placeholder="https://..."
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50" />
          </div>

        </div>
      </fieldset>

      <!-- Parametry druku (overrides) -->
      <fieldset class="bg-neutral-900 border border-white/10 rounded-xl p-6">
        <legend class="text-sm font-semibold text-amber-400 uppercase tracking-wider px-2 mb-4">Parametry druku (opcjonalne nadpisania)</legend>
        <p class="text-xs text-neutral-600 mb-4">Zostaw puste, aby używać wartości domyślnych z typu filamentu.</p>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Dysza min (°C)</label>
            <input type="number" name="nozzle_min" value="<%= brand ? (brand.nozzle_min || '') : '' %>"
              placeholder="<%= (parentType && (parentType.t_nozzle_min || parentType.nozzle_min)) ? 'Domyślnie: ' + (parentType.t_nozzle_min || parentType.nozzle_min) : 'np. 200' %>"
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50" />
          </div>

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Dysza max (°C)</label>
            <input type="number" name="nozzle_max" value="<%= brand ? (brand.nozzle_max || '') : '' %>"
              placeholder="<%= (parentType && (parentType.t_nozzle_max || parentType.nozzle_max)) ? 'Domyślnie: ' + (parentType.t_nozzle_max || parentType.nozzle_max) : 'np. 230' %>"
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50" />
          </div>

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Łoże min (°C)</label>
            <input type="number" name="bed_min" value="<%= brand ? (brand.bed_min || '') : '' %>"
              placeholder="<%= (parentType && (parentType.t_bed_min || parentType.bed_min)) ? 'Domyślnie: ' + (parentType.t_bed_min || parentType.bed_min) : 'np. 50' %>"
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50" />
          </div>

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Łoże max (°C)</label>
            <input type="number" name="bed_max" value="<%= brand ? (brand.bed_max || '') : '' %>"
              placeholder="<%= (parentType && (parentType.t_bed_max || parentType.bed_max)) ? 'Domyślnie: ' + (parentType.t_bed_max || parentType.bed_max) : 'np. 60' %>"
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50" />
          </div>

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Prędkość min (mm/s)</label>
            <input type="number" name="speed_min" value="<%= brand ? (brand.speed_min || '') : '' %>"
              placeholder="<%= (parentType && (parentType.t_speed_min || parentType.speed_min)) ? 'Domyślnie: ' + (parentType.t_speed_min || parentType.speed_min) : 'np. 30' %>"
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50" />
          </div>

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Prędkość max (mm/s)</label>
            <input type="number" name="speed_max" value="<%= brand ? (brand.speed_max || '') : '' %>"
              placeholder="<%= (parentType && (parentType.t_speed_max || parentType.speed_max)) ? 'Domyślnie: ' + (parentType.t_speed_max || parentType.speed_max) : 'np. 100' %>"
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50" />
          </div>

        </div>
      </fieldset>

      <!-- Uwagi PL/EN/DE -->
      <fieldset class="bg-neutral-900 border border-white/10 rounded-xl p-6">
        <legend class="text-sm font-semibold text-emerald-400 uppercase tracking-wider px-2 mb-4">Uwagi (PL / EN / DE)</legend>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Uwagi PL</label>
            <textarea name="notes_pl" rows="4" placeholder="Uwagi po polsku..."
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50 resize-y"><%= brand ? (brand.notes_pl || '') : '' %></textarea>
          </div>

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Uwagi EN</label>
            <textarea name="notes_en" rows="4" placeholder="Notes in English..."
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50 resize-y"><%= brand ? (brand.notes_en || '') : '' %></textarea>
          </div>

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Uwagi DE</label>
            <textarea name="notes_de" rows="4" placeholder="Hinweise auf Deutsch..."
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50 resize-y"><%= brand ? (brand.notes_de || '') : '' %></textarea>
          </div>

        </div>
      </fieldset>

      <!-- Metadane -->
      <fieldset class="bg-neutral-900 border border-white/10 rounded-xl p-6">
        <legend class="text-sm font-semibold text-rose-400 uppercase tracking-wider px-2 mb-4">Metadane</legend>
        <div class="flex flex-wrap gap-6">
          <div class="flex items-center gap-3">
            <input type="checkbox" name="is_verified" id="is_verified" <%= (brand && brand.is_verified) ? 'checked' : '' %> class="w-4 h-4 rounded border-white/20 bg-neutral-800 text-emerald-400" />
            <label for="is_verified" class="text-sm text-neutral-300">Zweryfikowana przez AEJaCA</label>
          </div>
          <div class="flex items-center gap-3">
            <input type="checkbox" name="is_active" id="is_active" <%= (brand ? brand.is_active : true) ? 'checked' : '' %> class="w-4 h-4 rounded border-white/20 bg-neutral-800 text-amber-400" />
            <label for="is_active" class="text-sm text-neutral-300">Aktywna (widoczna w API)</label>
          </div>
        </div>
        <% if (brand && brand.updated_at) { %>
        <div class="mt-4 text-xs text-neutral-600">
          Ostatnia zmiana: <%= new Date(brand.updated_at).toLocaleString('pl-PL') %>
          <% if (brand.updated_by) { %> przez <%= brand.updated_by %><% } %>
        </div>
        <% } %>
      </fieldset>

      <!-- Actions -->
      <div class="flex items-center justify-between pt-2">
        <a href="/filaments/<%= typeId %>/brands" class="text-sm text-neutral-400 hover:text-white transition-colors">&larr; Wróć do listy marek</a>
        <div class="flex items-center gap-3">
          <% if (brand) { %>
          <form method="POST" action="/filaments/brands/<%= brand.id %>/delete" onsubmit="return confirm('Usunąć markę #<%= brand.id %> (<%= (brand.brand || '').replace(/\'/g, '') %>)?')">
            <button type="submit" class="px-4 py-2 bg-red-950 border border-red-900/50 text-red-400 hover:text-red-300 text-sm rounded-lg transition-colors">
              &#128465; Usuń markę
            </button>
          </form>
          <% } %>
          <button type="submit" class="px-6 py-2 bg-amber-500 hover:bg-amber-400 text-neutral-950 text-sm font-medium rounded-lg transition-colors">
            &#128190; Zapisz
          </button>
        </div>
      </div>

    </form>

  </main>

</body>
</html>
