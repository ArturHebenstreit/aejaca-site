<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AEJaCA Admin — Leads</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            neutral: { 950: '#0a0a0a' }
          }
        }
      }
    }
  </script>
</head>
<body class="bg-neutral-950 min-h-screen text-neutral-100">

  <header class="bg-neutral-900 border-b border-white/10 px-6 py-3 flex items-center justify-between">
    <div class="flex items-center gap-6">
      <span class="text-lg font-bold text-white">AEJaCA <span class="text-amber-400">Admin</span></span>
      <nav class="flex gap-4 text-sm">
        <a href="/dashboard" class="text-neutral-400 hover:text-white transition-colors">Dashboard</a>
        <a href="/leads" class="text-white font-medium border-b border-amber-400 pb-0.5">Leads</a>
        <a href="/subscribers" class="text-neutral-400 hover:text-white transition-colors">Subscribers</a>
        <a href="/conversations" class="text-neutral-400 hover:text-white transition-colors">Chat</a>
      </nav>
    </div>
    <div class="flex items-center gap-3">
      <img src="<%= user.photo %>" class="w-7 h-7 rounded-full" alt="" />
      <span class="text-sm text-neutral-400"><%= user.name %></span>
      <a href="/logout" class="text-xs text-red-400 hover:text-red-300 transition-colors">Logout</a>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-6 py-8">

    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
      <h2 class="text-xl font-semibold text-white">Leads</h2>
      <a
        href="/export/leads"
        class="inline-flex items-center gap-2 px-4 py-2 bg-amber-500 hover:bg-amber-400 text-neutral-950 text-sm font-medium rounded-lg transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        Export CSV
      </a>
    </div>

    <!-- Stats summary -->
    <div class="flex flex-wrap gap-3 mb-6">
      <div class="bg-neutral-900 border border-white/10 rounded-xl px-5 py-3 flex items-center gap-3">
        <span class="text-neutral-500 text-sm">Total</span>
        <span class="text-2xl font-bold text-amber-400"><%= total %></span>
      </div>
      <% if (byCalc && byCalc.length > 0) { %>
        <% byCalc.forEach(function(item) { %>
        <div class="bg-neutral-900 border border-white/10 rounded-xl px-4 py-3 flex items-center gap-2">
          <span class="text-xs text-neutral-500 uppercase"><%= item.calculator %></span>
          <span class="text-lg font-semibold text-white"><%= item.count %></span>
        </div>
        <% }); %>
      <% } %>
    </div>

    <!-- Table -->
    <div class="bg-neutral-900 border border-white/10 rounded-xl overflow-hidden mb-6">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/10 text-neutral-500 text-xs uppercase tracking-wider">
              <th class="px-4 py-3 text-left whitespace-nowrap">Date</th>
              <th class="px-4 py-3 text-left">Email</th>
              <th class="px-4 py-3 text-left">Lang</th>
              <th class="px-4 py-3 text-left">Calculator</th>
              <th class="px-4 py-3 text-left">Params</th>
              <th class="px-4 py-3 text-right whitespace-nowrap">Min PLN</th>
              <th class="px-4 py-3 text-right whitespace-nowrap">Max PLN</th>
              <th class="px-4 py-3 text-right whitespace-nowrap">Min EUR</th>
              <th class="px-4 py-3 text-right whitespace-nowrap">Max EUR</th>
              <th class="px-4 py-3 text-right">Qty</th>
              <th class="px-4 py-3 text-right">Disc%</th>
              <th class="px-4 py-3 text-left">Status</th>
            </tr>
          </thead>
          <tbody>
            <% if (leads && leads.length > 0) { %>
              <% leads.forEach(function(lead, i) { %>
              <tr class="border-b border-white/5 hover:bg-white/[0.03] transition-colors <%= i % 2 === 1 ? 'bg-white/[0.015]' : '' %>">
                <td class="px-4 py-3 text-neutral-400 whitespace-nowrap text-xs">
                  <%= fmtDate(lead.created_at) %>
                </td>
                <td class="px-4 py-3 text-neutral-200 max-w-[160px] truncate">
                  <a href="mailto:<%= lead.email %>" class="hover:text-amber-400 transition-colors"><%= lead.email %></a>
                </td>
                <td class="px-4 py-3">
                  <span class="text-xs text-neutral-400 uppercase"><%= lead.lang || '—' %></span>
                </td>
                <td class="px-4 py-3">
                  <span class="px-2 py-0.5 bg-amber-950 text-amber-300 rounded text-xs font-medium whitespace-nowrap">
                    <%= lead.calculator %>
                  </span>
                </td>
                <td class="px-4 py-3 text-neutral-400 text-xs max-w-[180px]">
                  <% if (lead.params) { %>
                    <% try { %>
                      <% var p = typeof lead.params === 'string' ? JSON.parse(lead.params) : lead.params; %>
                      <span class="truncate block" title="<%= JSON.stringify(p) %>">
                        <%= Object.entries(p).map(function(e){ return e[0]+': '+e[1]; }).join(', ') %>
                      </span>
                    <% } catch(e) { %>
                      <%= lead.params %>
                    <% } %>
                  <% } else { %>
                    <span class="text-neutral-600">—</span>
                  <% } %>
                </td>
                <td class="px-4 py-3 text-right text-neutral-300">
                  <% if (lead.price_min_pln != null) { %><%= lead.price_min_pln %><% } else { %><span class="text-neutral-600">—</span><% } %>
                </td>
                <td class="px-4 py-3 text-right text-neutral-300">
                  <% if (lead.price_max_pln != null) { %><%= lead.price_max_pln %><% } else { %><span class="text-neutral-600">—</span><% } %>
                </td>
                <td class="px-4 py-3 text-right text-neutral-300">
                  <% if (lead.priceMinEur != null) { %><%= lead.priceMinEur %><% } else { %><span class="text-neutral-600">—</span><% } %>
                </td>
                <td class="px-4 py-3 text-right text-neutral-300">
                  <% if (lead.priceMaxEur != null) { %><%= lead.priceMaxEur %><% } else { %><span class="text-neutral-600">—</span><% } %>
                </td>
                <td class="px-4 py-3 text-right text-neutral-300">
                  <% if (lead.quantity != null) { %><%= lead.quantity %><% } else { %><span class="text-neutral-600">—</span><% } %>
                </td>
                <td class="px-4 py-3 text-right text-neutral-300">
                  <% if (lead.discount != null) { %><%= lead.discount %>%<% } else { %><span class="text-neutral-600">—</span><% } %>
                </td>
                <td class="px-4 py-3">
                  <% var statusMap = { new: 'bg-blue-950 text-blue-300', contacted: 'bg-amber-950 text-amber-300', closed: 'bg-emerald-950 text-emerald-300', spam: 'bg-neutral-800 text-neutral-500' }; %>
                  <% var statusClass = statusMap[lead.status] || 'bg-neutral-800 text-neutral-400'; %>
                  <span class="px-2 py-0.5 rounded text-xs font-medium <%= statusClass %>">
                    <%= lead.status || 'new' %>
                  </span>
                </td>
              </tr>
              <% }); %>
            <% } else { %>
            <tr>
              <td colspan="12" class="px-4 py-12 text-center text-neutral-600">No leads found.</td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Pagination -->
    <% if (pages > 1) { %>
    <div class="flex items-center justify-between">
      <span class="text-sm text-neutral-500">Page <%= page %> of <%= pages %></span>
      <div class="flex gap-2">
        <% if (page > 1) { %>
        <a href="/leads?page=<%= page - 1 %>" class="px-4 py-2 bg-neutral-900 border border-white/10 rounded-lg text-sm text-neutral-300 hover:text-white hover:border-white/20 transition-colors">
          &larr; Prev
        </a>
        <% } else { %>
        <span class="px-4 py-2 bg-neutral-900 border border-white/5 rounded-lg text-sm text-neutral-700 cursor-not-allowed">
          &larr; Prev
        </span>
        <% } %>

        <% if (page < pages) { %>
        <a href="/leads?page=<%= page + 1 %>" class="px-4 py-2 bg-neutral-900 border border-white/10 rounded-lg text-sm text-neutral-300 hover:text-white hover:border-white/20 transition-colors">
          Next &rarr;
        </a>
        <% } else { %>
        <span class="px-4 py-2 bg-neutral-900 border border-white/5 rounded-lg text-sm text-neutral-700 cursor-not-allowed">
          Next &rarr;
        </span>
        <% } %>
      </div>
    </div>
    <% } %>

  </main>

  <script>
    function fmtDate(d) {
      if (!d) return '—';
      const dt = new Date(d);
      return dt.toLocaleDateString('pl-PL') + ' ' + dt.toLocaleTimeString('pl-PL', { hour: '2-digit', minute: '2-digit' });
    }
  </script>

</body>
</html>
