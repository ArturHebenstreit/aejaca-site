<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AEJaCA Admin — Login</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            neutral: {
              950: '#0a0a0a'
            }
          }
        }
      }
    }
  </script>
</head>
<body class="bg-neutral-950 min-h-screen flex items-center justify-center">
  <div class="w-full max-w-sm px-6">

    <div class="text-center mb-10">
      <h1 class="text-3xl font-bold text-white tracking-tight">
        AEJ<span class="text-amber-400">a</span>CA
      </h1>
      <p class="text-neutral-500 text-sm mt-2 tracking-widest uppercase">Admin Panel</p>
    </div>

    <% if (typeof error !== 'undefined' && error === 'unauthorized') { %>
    <div class="mb-6 px-4 py-3 bg-red-950 border border-red-800 rounded-lg text-red-300 text-sm text-center">
      Unauthorized email address. Access denied.
    </div>
    <% } %>

    <div class="bg-neutral-900 border border-white/10 rounded-2xl p-8">
      <p class="text-neutral-400 text-sm text-center mb-6">
        Sign in to manage leads and subscribers.
      </p>
      <a
        href="/auth/google"
        class="flex items-center justify-center gap-3 w-full px-5 py-3 bg-white hover:bg-neutral-100 text-neutral-900 font-medium text-sm rounded-lg transition-colors"
      >
        <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 48 48">
          <path fill="#FFC107" d="M43.6 20.1H42V20H24v8h11.3C33.7 32.7 29.2 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.8 1.1 7.9 3l5.7-5.7C34.5 6.5 29.5 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.3-.1-2.6-.4-3.9z"/>
          <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.5 16 19 12 24 12c3.1 0 5.8 1.1 7.9 3l5.7-5.7C34.5 6.5 29.5 4 24 4 16.3 4 9.7 8.4 6.3 14.7z"/>
          <path fill="#4CAF50" d="M24 44c5.2 0 9.9-1.9 13.5-5.1l-6.2-5.2C29.4 35.5 26.8 36 24 36c-5.1 0-9.6-3.2-11.3-7.8l-6.5 5C9.5 39.4 16.3 44 24 44z"/>
          <path fill="#1976D2" d="M43.6 20.1H42V20H24v8h11.3c-.8 2.3-2.3 4.2-4.3 5.6l6.2 5.2C36.8 36.1 44 31 44 24c0-1.3-.1-2.6-.4-3.9z"/>
        </svg>
        Sign in with Google
      </a>
    </div>

    <p class="text-center text-neutral-700 text-xs mt-8">
      &copy; <%= new Date().getFullYear() %> AEJaCA
    </p>
  </div>
</body>
</html>
