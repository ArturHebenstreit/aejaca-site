<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AEJaCA Admin — Laser Matrix</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            neutral: { 950: '#0a0a0a' }
          }
        }
      }
    }
  </script>
</head>
<body class="bg-neutral-950 min-h-screen text-neutral-100">

  <header class="bg-neutral-900 border-b border-white/10 px-6 py-3 flex items-center justify-between">
    <div class="flex items-center gap-6">
      <span class="text-lg font-bold text-white">AEJaCA <span class="text-amber-400">Admin</span></span>
      <nav class="flex gap-4 text-sm">
        <a href="/dashboard" class="text-neutral-400 hover:text-white transition-colors">Dashboard</a>
        <a href="/analytics" class="text-neutral-400 hover:text-white transition-colors">Analytics</a>
        <a href="/leads" class="text-neutral-400 hover:text-white transition-colors">Leads</a>
        <a href="/subscribers" class="text-neutral-400 hover:text-white transition-colors">Subscribers</a>
        <a href="/conversations" class="text-neutral-400 hover:text-white transition-colors">Chat</a>
        <a href="/laser-matrix" class="text-white font-medium border-b border-amber-400 pb-0.5">Laser Matrix</a>
      </nav>
    </div>
    <div class="flex items-center gap-3">
      <img src="<%= user.photo %>" class="w-7 h-7 rounded-full" alt="" />
      <span class="text-sm text-neutral-400"><%= user.name %></span>
      <a href="/logout" class="text-xs text-red-400 hover:text-red-300 transition-colors">Logout</a>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-6 py-8">

    <!-- Flash banner -->
    <% if (filters.flash === 'created') { %>
    <div class="mb-5 px-4 py-3 bg-emerald-950 border border-emerald-700/50 text-emerald-300 rounded-lg text-sm">
      &#10003; Wiersz #<%= filters.id %> dodany
    </div>
    <% } else if (filters.flash === 'updated') { %>
    <div class="mb-5 px-4 py-3 bg-emerald-950 border border-emerald-700/50 text-emerald-300 rounded-lg text-sm">
      &#10003; Wiersz #<%= filters.id %> zaktualizowany
    </div>
    <% } else if (filters.flash === 'deleted') { %>
    <div class="mb-5 px-4 py-3 bg-neutral-800 border border-white/10 text-neutral-400 rounded-lg text-sm">
      &#128465; Wiersz usunięty
    </div>
    <% } %>

    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
      <h2 class="text-xl font-semibold text-white">Laser Matrix</h2>
      <div class="flex items-center gap-3">
        <a href="/laser-matrix/new" class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-lg transition-colors">
          + Nowy wiersz
        </a>
        <a href="/laser-matrix/export" class="inline-flex items-center gap-2 px-4 py-2 bg-neutral-700 hover:bg-neutral-600 text-neutral-200 text-sm font-medium rounded-lg transition-colors">
          &#128228; Export CSV
        </a>
      </div>
    </div>

    <!-- Stats row -->
    <div class="flex flex-wrap gap-3 mb-6">
      <div class="bg-neutral-900 border border-white/10 rounded-xl px-5 py-3 flex items-center gap-3">
        <span class="text-neutral-500 text-sm">Łącznie</span>
        <span class="text-2xl font-bold text-amber-400"><%= grandTotal %></span>
        <span class="text-neutral-500 text-xs">wierszy</span>
      </div>
      <% if (stats && stats.length > 0) { %>
        <% stats.forEach(function(s) { %>
        <div class="bg-neutral-900 border border-white/10 rounded-xl px-4 py-3 flex items-center gap-2">
          <span class="text-xs text-neutral-500 uppercase"><%= s.laser_type %></span>
          <span class="text-lg font-semibold text-white"><%= s.cnt %></span>
        </div>
        <% }); %>
      <% } %>
    </div>

    <!-- Filter bar -->
    <form method="GET" action="/laser-matrix" class="flex flex-wrap gap-3 mb-6">
      <select name="laser" class="bg-neutral-800 border border-white/10 text-neutral-300 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50">
        <option value="">Wszystkie lasery</option>
        <% options.lasers.forEach(function(l) { %>
        <option value="<%= l %>" <%= filters.laser === l ? 'selected' : '' %>><%= l %></option>
        <% }); %>
      </select>
      <select name="action" class="bg-neutral-800 border border-white/10 text-neutral-300 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50">
        <option value="">Wszystkie akcje</option>
        <% options.actions.forEach(function(a) { %>
        <option value="<%= a %>" <%= filters.action === a ? 'selected' : '' %>><%= a %></option>
        <% }); %>
      </select>
      <input type="text" name="material" value="<%= filters.material || '' %>" placeholder="Szukaj materiału..." class="bg-neutral-800 border border-white/10 text-neutral-300 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50 w-48" />
      <select name="watts" class="bg-neutral-800 border border-white/10 text-neutral-300 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50">
        <option value="">Wszystkie moce</option>
        <% options.watts.forEach(function(w) { %>
        <option value="<%= w %>" <%= filters.watts == w ? 'selected' : '' %>><%= w %> W</option>
        <% }); %>
      </select>
      <button type="submit" class="px-4 py-2 bg-amber-500 hover:bg-amber-400 text-neutral-950 text-sm font-medium rounded-lg transition-colors">Filtruj</button>
      <a href="/laser-matrix" class="px-4 py-2 bg-neutral-800 hover:bg-neutral-700 text-neutral-400 hover:text-white text-sm rounded-lg transition-colors">Wyczyść</a>
    </form>

    <!-- Table -->
    <div class="bg-neutral-900 border border-white/10 rounded-xl overflow-hidden mb-6">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/10 text-neutral-500 text-xs uppercase tracking-wider">
              <th class="px-4 py-3 text-left">ID</th>
              <th class="px-4 py-3 text-left">Laser</th>
              <th class="px-4 py-3 text-left">Akcja</th>
              <th class="px-4 py-3 text-left">Materiał</th>
              <th class="px-4 py-3 text-right">Watts</th>
              <th class="px-4 py-3 text-right">Speed</th>
              <th class="px-4 py-3 text-right">Power%</th>
              <th class="px-4 py-3 text-left">Uwagi</th>
              <th class="px-4 py-3 text-right"></th>
            </tr>
          </thead>
          <tbody>
            <% if (rows && rows.length > 0) { %>
              <% rows.forEach(function(row, i) { %>
              <tr class="border-b border-white/5 hover:bg-white/[0.03] transition-colors group <%= i % 2 === 1 ? 'bg-white/[0.015]' : '' %>">
                <td class="px-4 py-3 text-neutral-600 text-xs font-mono"><%= row.id %></td>
                <td class="px-4 py-3">
                  <span class="px-2 py-0.5 bg-blue-950 text-blue-300 rounded text-xs font-medium whitespace-nowrap"><%= row.laser_type || '—' %></span>
                </td>
                <td class="px-4 py-3">
                  <span class="px-2 py-0.5 bg-amber-950 text-amber-300 rounded text-xs font-medium whitespace-nowrap"><%= row.action_type || '—' %></span>
                </td>
                <td class="px-4 py-3 text-neutral-200 max-w-[160px] truncate"><%= row.material || '—' %></td>
                <td class="px-4 py-3 text-right text-neutral-300 whitespace-nowrap"><%= row.watts != null ? row.watts : '—' %></td>
                <td class="px-4 py-3 text-right text-neutral-400 text-xs whitespace-nowrap"><%= row.speed != null ? row.speed : '—' %></td>
                <td class="px-4 py-3 text-right text-neutral-400 text-xs whitespace-nowrap"><%= row.power_pct != null ? row.power_pct + '%' : '—' %></td>
                <td class="px-4 py-3 text-neutral-500 text-xs max-w-[200px] truncate" title="<%= row.notes || '' %>">
                  <%= row.notes ? row.notes.substring(0, 60) + (row.notes.length > 60 ? '…' : '') : '—' %>
                </td>
                <td class="px-4 py-3 whitespace-nowrap text-right">
                  <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                    <a href="/laser-matrix/<%= row.id %>/edit" class="text-amber-400 hover:text-amber-300 text-sm transition-colors" title="Edytuj">&#9998;</a>
                    <form method="POST" action="/laser-matrix/<%= row.id %>/delete" onsubmit="return confirm('Usunąć wiersz #<%= row.id %>?')">
                      <button type="submit" class="text-red-500 hover:text-red-400 text-sm transition-colors" title="Usuń">&#128465;</button>
                    </form>
                  </div>
                </td>
              </tr>
              <% }); %>
            <% } else { %>
            <tr>
              <td colspan="9" class="px-4 py-12 text-center text-neutral-600">Brak wierszy. <a href="/laser-matrix/new" class="text-amber-400 hover:text-amber-300">Dodaj pierwszy.</a></td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-between">
      <span class="text-sm text-neutral-500">
        <% var from = (page - 1) * 50 + 1; var to = Math.min(page * 50, total); %>
        <% if (total > 0) { %>Showing <%= from %>–<%= to %> of <%= total %><% } else { %>Brak wyników<% } %>
      </span>
      <% if (pages > 1) { %>
      <div class="flex gap-2">
        <% if (page > 1) { %>
        <a href="/laser-matrix?page=<%= page - 1 %>&laser=<%= filters.laser || '' %>&action=<%= filters.action || '' %>&material=<%= filters.material || '' %>&watts=<%= filters.watts || '' %>" class="px-4 py-2 bg-neutral-900 border border-white/10 rounded-lg text-sm text-neutral-300 hover:text-white hover:border-white/20 transition-colors">
          &larr; Prev
        </a>
        <% } else { %>
        <span class="px-4 py-2 bg-neutral-900 border border-white/5 rounded-lg text-sm text-neutral-700 cursor-not-allowed">&larr; Prev</span>
        <% } %>
        <% if (page < pages) { %>
        <a href="/laser-matrix?page=<%= page + 1 %>&laser=<%= filters.laser || '' %>&action=<%= filters.action || '' %>&material=<%= filters.material || '' %>&watts=<%= filters.watts || '' %>" class="px-4 py-2 bg-neutral-900 border border-white/10 rounded-lg text-sm text-neutral-300 hover:text-white hover:border-white/20 transition-colors">
          Next &rarr;
        </a>
        <% } else { %>
        <span class="px-4 py-2 bg-neutral-900 border border-white/5 rounded-lg text-sm text-neutral-700 cursor-not-allowed">Next &rarr;</span>
        <% } %>
      </div>
      <% } %>
    </div>

  </main>

</body>
</html>
