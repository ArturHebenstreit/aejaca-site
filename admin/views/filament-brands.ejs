<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AEJaCA Admin — Marki — <%= type.name || type.type_id %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            neutral: { 950: '#0a0a0a' }
          }
        }
      }
    }
  </script>
</head>
<body class="bg-neutral-950 min-h-screen text-neutral-100">

  <header class="bg-neutral-900 border-b border-white/10 px-6 py-3 flex items-center justify-between">
    <div class="flex items-center gap-6">
      <span class="text-lg font-bold text-white">AEJaCA <span class="text-amber-400">Admin</span></span>
      <nav class="flex gap-4 text-sm">
        <a href="/dashboard" class="text-neutral-400 hover:text-white transition-colors">Dashboard</a>
        <a href="/analytics" class="text-neutral-400 hover:text-white transition-colors">Analytics</a>
        <a href="/leads" class="text-neutral-400 hover:text-white transition-colors">Leads</a>
        <a href="/subscribers" class="text-neutral-400 hover:text-white transition-colors">Subscribers</a>
        <a href="/conversations" class="text-neutral-400 hover:text-white transition-colors">Chat</a>
        <a href="/orders" class="text-neutral-400 hover:text-white transition-colors">Zamówienia</a>
        <a href="/laser-matrix" class="text-neutral-400 hover:text-white transition-colors">Laser Matrix</a>
        <a href="/gemstone-prices" class="text-neutral-400 hover:text-white transition-colors">Gems</a>
        <a href="/filaments" class="text-white font-medium border-b border-amber-400 pb-0.5">Filamenty<% if (pendingContributions > 0) { %> <span class="text-amber-400">(<%= pendingContributions %>)</span><% } %></a>
      </nav>
    </div>
    <div class="flex items-center gap-3">
      <img src="<%= user.photo %>" class="w-7 h-7 rounded-full" alt="" />
      <span class="text-sm text-neutral-400"><%= user.name %></span>
      <a href="/logout" class="text-xs text-red-400 hover:text-red-300 transition-colors">Logout</a>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-6 py-8">

    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-neutral-500 mb-6">
      <a href="/filaments" class="hover:text-amber-400 transition-colors">&larr; Filamenty</a>
      <span>&rsaquo;</span>
      <a href="/filaments/<%= type.id %>/edit" class="hover:text-amber-400 transition-colors"><%= type.name || type.type_id %></a>
      <span>&rsaquo;</span>
      <span class="text-neutral-300">Marki</span>
    </div>

    <!-- Flash banner -->
    <% if (filters.flash === 'created') { %>
    <div class="mb-5 px-4 py-3 bg-emerald-950 border border-emerald-700/50 text-emerald-300 rounded-lg text-sm">
      &#10003; Marka #<%= filters.id %> dodana
    </div>
    <% } else if (filters.flash === 'updated') { %>
    <div class="mb-5 px-4 py-3 bg-emerald-950 border border-emerald-700/50 text-emerald-300 rounded-lg text-sm">
      &#10003; Marka #<%= filters.id %> zaktualizowana
    </div>
    <% } else if (filters.flash === 'deleted') { %>
    <div class="mb-5 px-4 py-3 bg-neutral-800 border border-white/10 text-neutral-400 rounded-lg text-sm">
      &#128465; Marka usunięta
    </div>
    <% } %>

    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
      <div>
        <h2 class="text-xl font-semibold text-white">Marki — <span class="text-amber-400"><%= type.name || type.type_id %></span></h2>
        <p class="text-sm text-neutral-500 mt-1 font-mono"><%= type.type_id %> &middot; <%= type.category || '—' %></p>
      </div>
      <a href="/filaments/<%= type.id %>/brands/new" class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-lg transition-colors">
        + Nowa marka
      </a>
    </div>

    <!-- Stats row -->
    <div class="flex flex-wrap gap-3 mb-6">
      <div class="bg-neutral-900 border border-white/10 rounded-xl px-5 py-3 flex items-center gap-3">
        <span class="text-neutral-500 text-sm">Łącznie</span>
        <span class="text-2xl font-bold text-amber-400"><%= total %></span>
        <span class="text-neutral-500 text-xs">marek</span>
      </div>
      <% var verifiedCount = brands.filter(function(b) { return b.is_verified; }).length; %>
      <% var communityCount = brands.filter(function(b) { return b.auto_approved; }).length; %>
      <% if (verifiedCount > 0) { %>
      <div class="bg-neutral-900 border border-white/10 rounded-xl px-4 py-3 flex items-center gap-2">
        <span class="bg-emerald-500/20 text-emerald-300 text-xs px-2 py-0.5 rounded">Zweryfikowane</span>
        <span class="text-lg font-semibold text-white"><%= verifiedCount %></span>
      </div>
      <% } %>
      <% if (communityCount > 0) { %>
      <div class="bg-neutral-900 border border-white/10 rounded-xl px-4 py-3 flex items-center gap-2">
        <span class="bg-amber-500/20 text-amber-300 text-xs px-2 py-0.5 rounded">Soc. zatwierdzone</span>
        <span class="text-lg font-semibold text-white"><%= communityCount %></span>
      </div>
      <% } %>
      <!-- Type defaults reference -->
      <div class="bg-neutral-900 border border-white/10 rounded-xl px-4 py-3 text-xs text-neutral-500">
        <span class="text-neutral-400">Domyślnie dysza:</span> <%= type.nozzle_min || '?' %>–<%= type.nozzle_max || '?' %>°C &nbsp;
        <span class="text-neutral-400">łoże:</span> <%= type.bed_min || '?' %>–<%= type.bed_max || '?' %>°C
      </div>
    </div>

    <!-- Table -->
    <div class="bg-neutral-900 border border-white/10 rounded-xl overflow-hidden mb-6">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/10 text-neutral-500 text-xs uppercase tracking-wider">
              <th class="px-4 py-3 text-left">ID</th>
              <th class="px-4 py-3 text-left">Marka</th>
              <th class="px-4 py-3 text-left">Produkt</th>
              <th class="px-4 py-3 text-right">Dysza °C</th>
              <th class="px-4 py-3 text-right">Łoże °C</th>
              <th class="px-4 py-3 text-right">Prędkość mm/s</th>
              <th class="px-4 py-3 text-left">Zweryfikowana</th>
              <th class="px-4 py-3 text-left">Aktywna</th>
              <th class="px-4 py-3 text-right"></th>
            </tr>
          </thead>
          <tbody>
            <% if (brands && brands.length > 0) { %>
              <% brands.forEach(function(brand, i) { %>
              <tr class="border-b border-white/5 hover:bg-white/[0.03] transition-colors group <%= i % 2 === 1 ? 'bg-white/[0.015]' : '' %>">
                <td class="px-4 py-3 text-neutral-600 text-xs font-mono"><%= brand.id %></td>
                <td class="px-4 py-3 font-medium text-neutral-200"><%= brand.brand || '—' %></td>
                <td class="px-4 py-3 text-neutral-300 max-w-[200px]">
                  <div class="truncate"><%= brand.product_name || '—' %></div>
                  <% if (brand.product_url) { %>
                  <a href="<%= brand.product_url %>" target="_blank" rel="noopener" class="text-xs text-blue-400 hover:text-blue-300 truncate block">&#128279; link</a>
                  <% } %>
                </td>
                <td class="px-4 py-3 text-right text-neutral-300 text-xs whitespace-nowrap">
                  <% if (brand.nozzle_min || brand.nozzle_max) { %>
                  <span class="text-amber-300"><%= brand.nozzle_min || '?' %>–<%= brand.nozzle_max || '?' %>°C</span>
                  <% } else { %>
                  <span class="text-neutral-600">typ: <%= type.nozzle_min || '?' %>–<%= type.nozzle_max || '?' %>°C</span>
                  <% } %>
                </td>
                <td class="px-4 py-3 text-right text-neutral-400 text-xs whitespace-nowrap">
                  <% if (brand.bed_min || brand.bed_max) { %>
                  <span class="text-amber-300"><%= brand.bed_min || '?' %>–<%= brand.bed_max || '?' %>°C</span>
                  <% } else { %>
                  <span class="text-neutral-600">typ: <%= type.bed_min || '?' %>–<%= type.bed_max || '?' %>°C</span>
                  <% } %>
                </td>
                <td class="px-4 py-3 text-right text-neutral-400 text-xs whitespace-nowrap">
                  <% if (brand.speed_min || brand.speed_max) { %>
                  <span class="text-amber-300"><%= brand.speed_min || '?' %>–<%= brand.speed_max || '?' %></span>
                  <% } else { %>
                  <span class="text-neutral-600">—</span>
                  <% } %>
                </td>
                <td class="px-4 py-3">
                  <% if (brand.is_verified) { %>
                  <span class="bg-emerald-500/20 text-emerald-300 text-[10px] px-1.5 py-0.5 rounded">Zweryfikowana &#10003;</span>
                  <% } else if (brand.auto_approved) { %>
                  <span class="bg-amber-500/20 text-amber-300 text-[10px] px-1.5 py-0.5 rounded">Soc. &#10003; (<%= brand.vote_confirm_count || 0 %> głosów)</span>
                  <% } else { %>
                  <span class="text-neutral-600 text-xs">—</span>
                  <% } %>
                </td>
                <td class="px-4 py-3">
                  <% if (brand.is_active) { %>
                  <span class="text-emerald-400 text-xs">&#10003; aktywna</span>
                  <% } else { %>
                  <span class="text-red-500 text-xs">&#10007; nieaktywna</span>
                  <% } %>
                </td>
                <td class="px-4 py-3 whitespace-nowrap text-right">
                  <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                    <a href="/filaments/brands/<%= brand.id %>/edit" class="text-amber-400 hover:text-amber-300 text-sm transition-colors" title="Edytuj">&#9998;</a>
                    <form method="POST" action="/filaments/brands/<%= brand.id %>/delete" onsubmit="return confirm('Usunąć markę #<%= brand.id %> (<%= (brand.brand || '').replace(/\'/g, '') %>)?')">
                      <button type="submit" class="text-red-500 hover:text-red-400 text-sm transition-colors" title="Usuń">&#128465;</button>
                    </form>
                  </div>
                </td>
              </tr>
              <% }); %>
            <% } else { %>
            <tr>
              <td colspan="9" class="px-4 py-12 text-center text-neutral-600">Brak marek dla tego typu. <a href="/filaments/<%= type.id %>/brands/new" class="text-amber-400 hover:text-amber-300">Dodaj pierwszą.</a></td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-between">
      <span class="text-sm text-neutral-500">
        <% var from = (page - 1) * 50 + 1; var to = Math.min(page * 50, total); %>
        <% if (total > 0) { %>Showing <%= from %>–<%= to %> of <%= total %><% } else { %>Brak marek<% } %>
      </span>
      <% if (pages > 1) { %>
      <div class="flex gap-2">
        <% if (page > 1) { %>
        <a href="/filaments/<%= type.id %>/brands?page=<%= page - 1 %>" class="px-4 py-2 bg-neutral-900 border border-white/10 rounded-lg text-sm text-neutral-300 hover:text-white hover:border-white/20 transition-colors">
          &larr; Prev
        </a>
        <% } else { %>
        <span class="px-4 py-2 bg-neutral-900 border border-white/5 rounded-lg text-sm text-neutral-700 cursor-not-allowed">&larr; Prev</span>
        <% } %>
        <% if (page < pages) { %>
        <a href="/filaments/<%= type.id %>/brands?page=<%= page + 1 %>" class="px-4 py-2 bg-neutral-900 border border-white/10 rounded-lg text-sm text-neutral-300 hover:text-white hover:border-white/20 transition-colors">
          Next &rarr;
        </a>
        <% } else { %>
        <span class="px-4 py-2 bg-neutral-900 border border-white/5 rounded-lg text-sm text-neutral-700 cursor-not-allowed">Next &rarr;</span>
        <% } %>
      </div>
      <% } %>
    </div>

  </main>

</body>
</html>
