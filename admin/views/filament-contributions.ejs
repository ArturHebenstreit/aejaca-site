<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AEJaCA Admin — Zgłoszenia filamentów</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            neutral: { 950: '#0a0a0a' }
          }
        }
      }
    }
  </script>
</head>
<body class="bg-neutral-950 min-h-screen text-neutral-100">

  <header class="bg-neutral-900 border-b border-white/10 px-6 py-3 flex items-center justify-between">
    <div class="flex items-center gap-6">
      <span class="text-lg font-bold text-white">AEJaCA <span class="text-amber-400">Admin</span></span>
      <nav class="flex gap-4 text-sm">
        <a href="/dashboard" class="text-neutral-400 hover:text-white transition-colors">Dashboard</a>
        <a href="/analytics" class="text-neutral-400 hover:text-white transition-colors">Analytics</a>
        <a href="/leads" class="text-neutral-400 hover:text-white transition-colors">Leads</a>
        <a href="/subscribers" class="text-neutral-400 hover:text-white transition-colors">Subscribers</a>
        <a href="/conversations" class="text-neutral-400 hover:text-white transition-colors">Chat</a>
        <a href="/email-threads" class="text-neutral-400 hover:text-white transition-colors">Email</a>
        <a href="/laser-matrix" class="text-neutral-400 hover:text-white transition-colors">Laser Matrix</a>
        <a href="/gemstone-prices" class="text-neutral-400 hover:text-white transition-colors">Gems</a>
        <a href="/filaments" class="text-white font-medium border-b border-amber-400 pb-0.5">Filamenty<% if (pendingContributions > 0) { %> <span class="text-amber-400">(<%= pendingContributions %>)</span><% } %></a>
      </nav>
    </div>
    <div class="flex items-center gap-3">
      <img src="<%= user.photo %>" class="w-7 h-7 rounded-full" alt="" />
      <span class="text-sm text-neutral-400"><%= user.name %></span>
      <a href="/logout" class="text-xs text-red-400 hover:text-red-300 transition-colors">Logout</a>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-6 py-8">

    <!-- Flash banner -->
    <% if (filters.flash === 'approved') { %>
    <div class="mb-5 px-4 py-3 bg-emerald-950 border border-emerald-700/50 text-emerald-300 rounded-lg text-sm">
      &#10003; Zgłoszenie zatwierdzone i dodane jako zweryfikowana marka
    </div>
    <% } else if (filters.flash === 'rejected') { %>
    <div class="mb-5 px-4 py-3 bg-neutral-800 border border-white/10 text-neutral-400 rounded-lg text-sm">
      &#10007; Zgłoszenie odrzucone
    </div>
    <% } %>

    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-neutral-500 mb-6">
      <a href="/filaments" class="hover:text-amber-400 transition-colors">&larr; Filamenty</a>
      <span>&rsaquo;</span>
      <span class="text-neutral-300">Zgłoszenia użytkowników</span>
    </div>

    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
      <div class="flex items-center gap-3">
        <h2 class="text-xl font-semibold text-white">Zgłoszenia użytkowników</h2>
        <% if (pendingContributions > 0) { %>
        <span class="bg-amber-500 text-neutral-950 text-xs font-bold px-2 py-0.5 rounded-full"><%= pendingContributions %> oczekuje</span>
        <% } %>
      </div>

      <!-- Filter by status -->
      <form method="GET" action="/filaments/contributions" class="flex items-center gap-2">
        <select name="status" class="bg-neutral-800 border border-white/10 text-neutral-300 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50">
          <option value="pending" <%= (!filters.status || filters.status === 'pending') ? 'selected' : '' %>>Oczekujące</option>
          <option value="approved" <%= filters.status === 'approved' ? 'selected' : '' %>>Zatwierdzone</option>
          <option value="rejected" <%= filters.status === 'rejected' ? 'selected' : '' %>>Odrzucone</option>
          <option value="all" <%= filters.status === 'all' ? 'selected' : '' %>>Wszystkie</option>
        </select>
        <button type="submit" class="px-4 py-2 bg-amber-500 hover:bg-amber-400 text-neutral-950 text-sm font-medium rounded-lg transition-colors">Filtruj</button>
      </form>
    </div>

    <!-- Table -->
    <div class="bg-neutral-900 border border-white/10 rounded-xl overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/10 text-neutral-500 text-xs uppercase tracking-wider">
              <th class="px-4 py-3 text-left">ID</th>
              <th class="px-4 py-3 text-left">Typ filamentu</th>
              <th class="px-4 py-3 text-left">Marka</th>
              <th class="px-4 py-3 text-left">Produkt</th>
              <th class="px-4 py-3 text-right">Dysza °C</th>
              <th class="px-4 py-3 text-right">Łoże °C</th>
              <th class="px-4 py-3 text-center">Głosy</th>
              <th class="px-4 py-3 text-left">Email</th>
              <th class="px-4 py-3 text-left">Data</th>
              <th class="px-4 py-3 text-left">Status</th>
              <th class="px-4 py-3 text-right">Akcje</th>
            </tr>
          </thead>
          <tbody>
            <% if (rows && rows.length > 0) { %>
              <% var statusColors = { pending: 'text-amber-300 bg-amber-950', approved: 'text-emerald-300 bg-emerald-950', rejected: 'text-neutral-400 bg-neutral-800' }; %>
              <% rows.forEach(function(row, i) { %>
              <tr class="border-b border-white/5 hover:bg-white/[0.03] transition-colors group <%= i % 2 === 1 ? 'bg-white/[0.015]' : '' %>">
                <td class="px-4 py-3 text-neutral-600 text-xs font-mono"><%= row.id %></td>
                <td class="px-4 py-3 text-neutral-300 text-xs">
                  <%= row.type_name || '—' %>
                </td>
                <td class="px-4 py-3 font-medium text-neutral-200"><%= row.brand_name || '—' %></td>
                <td class="px-4 py-3 text-neutral-400 text-xs max-w-[160px] truncate" title="<%= row.product_name || '' %>">
                  <%= row.product_name || '—' %>
                </td>
                <td class="px-4 py-3 text-right text-neutral-300 text-xs whitespace-nowrap">
                  <% if (row.nozzle_min || row.nozzle_max) { %><%= row.nozzle_min || '?' %>–<%= row.nozzle_max || '?' %>°C<% } else { %><span class="text-neutral-600">—</span><% } %>
                </td>
                <td class="px-4 py-3 text-right text-neutral-400 text-xs whitespace-nowrap">
                  <% if (row.bed_min || row.bed_max) { %><%= row.bed_min || '?' %>–<%= row.bed_max || '?' %>°C<% } else { %><span class="text-neutral-600">—</span><% } %>
                </td>
                <td class="px-4 py-3 text-center whitespace-nowrap">
                  <span class="text-emerald-400 text-xs font-medium">&#128077; <%= row.vote_confirm_count || row.vote_confirm || 0 %></span>
                  <span class="text-neutral-600 mx-1">·</span>
                  <span class="text-red-400 text-xs font-medium">&#128078; <%= row.vote_dispute_count || row.vote_dispute || 0 %></span>
                </td>
                <td class="px-4 py-3 text-neutral-500 text-xs max-w-[160px] truncate" title="<%= row.contributor_email || '' %>">
                  <%= row.contributor_email || '—' %>
                </td>
                <td class="px-4 py-3 text-neutral-600 text-xs whitespace-nowrap">
                  <%= row.created_at ? new Date(row.created_at).toLocaleDateString('pl-PL') : '—' %>
                </td>
                <td class="px-4 py-3">
                  <span class="px-2 py-0.5 rounded text-xs font-medium <%= statusColors[row.status] || 'bg-neutral-800 text-neutral-400' %>">
                    <%= row.status || '—' %>
                  </span>
                </td>
                <td class="px-4 py-3 text-right">
                  <% if (row.status === 'pending') { %>
                  <div class="flex items-center justify-end gap-2">

                    <!-- Approve -->
                    <form method="POST" action="/filaments/contributions/<%= row.id %>/approve"
                      onsubmit="return confirm('Dodać jako markę zweryfikowaną? Zostanie wstawiona do bazy jako nowa marka.')">
                      <button type="submit" class="px-3 py-1.5 bg-emerald-700 hover:bg-emerald-600 text-white text-xs font-medium rounded-lg transition-colors whitespace-nowrap">
                        &#10003; Zatwierdź
                      </button>
                    </form>

                    <!-- Reject (inline expand) -->
                    <button type="button"
                      onclick="document.getElementById('reject-form-<%= row.id %>').classList.toggle('hidden')"
                      class="px-3 py-1.5 bg-red-950 hover:bg-red-900 border border-red-900/50 text-red-400 hover:text-red-300 text-xs font-medium rounded-lg transition-colors whitespace-nowrap">
                      &#10007; Odrzuć
                    </button>

                  </div>

                  <!-- Reject form (hidden, inline) -->
                  <div id="reject-form-<%= row.id %>" class="hidden mt-2">
                    <form method="POST" action="/filaments/contributions/<%= row.id %>/reject" class="flex flex-col gap-2">
                      <textarea name="admin_note" rows="2" placeholder="Powód odrzucenia (opcjonalnie)..."
                        class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-xs rounded-lg px-3 py-2 focus:outline-none focus:border-red-400/50 resize-none"></textarea>
                      <button type="submit" class="self-end px-3 py-1.5 bg-red-700 hover:bg-red-600 text-white text-xs font-medium rounded-lg transition-colors">
                        Potwierdź odrzucenie
                      </button>
                    </form>
                  </div>

                  <% } else if (row.status === 'approved') { %>
                  <span class="text-emerald-500 text-xs">Zatwierdzone</span>
                  <% if (row.reviewed_by) { %><div class="text-neutral-600 text-xs">przez <%= row.reviewed_by %></div><% } %>
                  <% } else if (row.status === 'rejected') { %>
                  <span class="text-neutral-500 text-xs">Odrzucone</span>
                  <% if (row.admin_note) { %>
                  <div class="text-neutral-600 text-xs mt-1 max-w-[200px] truncate" title="<%= row.admin_note %>"><%= row.admin_note %></div>
                  <% } %>
                  <% } %>
                </td>
              </tr>
              <% }); %>
            <% } else { %>
            <tr>
              <td colspan="11" class="px-4 py-12 text-center text-neutral-600">
                <% if (!filters.status || filters.status === 'pending') { %>
                Brak oczekujących zgłoszeń.
                <% } else { %>
                Brak zgłoszeń dla wybranego statusu.
                <% } %>
              </td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  </main>

</body>
</html>
