<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AEJaCA Admin — Zamówienia</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            neutral: { 950: '#0a0a0a' }
          }
        }
      }
    }
  </script>
</head>
<body class="bg-neutral-950 min-h-screen text-neutral-100">

  <header class="bg-neutral-900 border-b border-white/10 px-6 py-3 flex items-center justify-between">
    <div class="flex items-center gap-6">
      <span class="text-lg font-bold text-white">AEJaCA <span class="text-amber-400">Admin</span></span>
      <nav class="flex gap-4 text-sm">
        <a href="/dashboard" class="text-neutral-400 hover:text-white transition-colors">Dashboard</a>
        <a href="/analytics" class="text-neutral-400 hover:text-white transition-colors">Analytics</a>
        <a href="/leads" class="text-neutral-400 hover:text-white transition-colors">Leads</a>
        <a href="/subscribers" class="text-neutral-400 hover:text-white transition-colors">Subscribers</a>
        <a href="/conversations" class="text-neutral-400 hover:text-white transition-colors">Chat</a>
        <a href="/orders" class="text-white font-medium border-b border-amber-400 pb-0.5">Zamówienia<% if (pendingCount > 0) { %> <span class="text-amber-400">(<%= pendingCount %>)</span><% } %></a>
        <a href="/laser-matrix" class="text-neutral-400 hover:text-white transition-colors">Laser Matrix</a>
        <a href="/gemstone-prices" class="text-neutral-400 hover:text-white transition-colors">Gems</a>
        <a href="/filaments" class="text-neutral-400 hover:text-white transition-colors">Filamenty</a>
      </nav>
    </div>
    <div class="flex items-center gap-3">
      <img src="<%= user.photo %>" class="w-7 h-7 rounded-full" alt="" />
      <span class="text-sm text-neutral-400"><%= user.name %></span>
      <a href="/logout" class="text-xs text-red-400 hover:text-red-300 transition-colors">Logout</a>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-6 py-8">

    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
      <h2 class="text-xl font-semibold text-white">Zamówienia</h2>
    </div>

    <!-- Status filter tabs -->
    <div class="flex flex-wrap gap-2 mb-4">
      <%
        var tabDefs = [
          { key: '', label: 'Wszystkie' },
          { key: 'pending', label: 'Oczekujące' },
          { key: 'confirmed', label: 'Potwierdzone' },
          { key: 'in_production', label: 'W produkcji' },
          { key: 'shipped', label: 'Wysłane' },
          { key: 'delivered', label: 'Dostarczone' },
          { key: 'cancelled', label: 'Anulowane' },
        ];
        tabDefs.forEach(function(tab) {
          var isActive = currentStatus === tab.key;
          var cnt = counts.find(function(c) { return c.status === tab.key; });
          var badge = cnt ? parseInt(cnt.count) : 0;
      %>
      <a href="/orders<%= tab.key ? '?status=' + tab.key : '' %>"
         class="px-3 py-1.5 rounded-lg text-xs font-medium transition-colors <%= isActive ? 'bg-amber-500 text-neutral-950' : 'bg-neutral-800 text-neutral-400 hover:text-white' %>">
        <%= tab.label %><% if (tab.key && badge > 0) { %> <span class="<%= isActive ? 'text-neutral-800' : 'text-neutral-500' %>">(<%= badge %>)</span><% } %>
      </a>
      <% }); %>
    </div>

    <!-- Search -->
    <form method="GET" action="/orders" class="mb-6 flex gap-2">
      <% if (currentStatus) { %><input type="hidden" name="status" value="<%= currentStatus %>" /><% } %>
      <input type="text" name="search" value="<%= search %>"
             placeholder="Szukaj po nazwisku, e-mailu lub nr zamówienia..."
             class="flex-1 bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-4 py-2 placeholder:text-neutral-600 focus:outline-none focus:border-amber-500/50" />
      <button type="submit" class="px-4 py-2 bg-neutral-700 hover:bg-neutral-600 text-sm text-white rounded-lg transition-colors">Szukaj</button>
      <% if (search) { %>
      <a href="/orders<%= currentStatus ? '?status=' + currentStatus : '' %>" class="px-4 py-2 bg-neutral-800 hover:bg-neutral-700 text-sm text-neutral-400 rounded-lg transition-colors">Wyczyść</a>
      <% } %>
    </form>

    <!-- Table -->
    <div class="bg-neutral-900 border border-white/10 rounded-xl overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/10 text-neutral-500 text-xs uppercase tracking-wider">
              <th class="px-4 py-3 text-left whitespace-nowrap">Nr zamówienia</th>
              <th class="px-4 py-3 text-left whitespace-nowrap">Data</th>
              <th class="px-4 py-3 text-left">Klient</th>
              <th class="px-4 py-3 text-left">E-mail</th>
              <th class="px-4 py-3 text-left">Kraj</th>
              <th class="px-4 py-3 text-left">Dostawa</th>
              <th class="px-4 py-3 text-right whitespace-nowrap">Razem brutto</th>
              <th class="px-4 py-3 text-left">Status</th>
              <th class="px-4 py-3 text-left">Akcje</th>
            </tr>
          </thead>
          <tbody>
            <% if (orders && orders.length > 0) { %>
              <%
                var statusBadge = {
                  pending:       'bg-amber-950 text-amber-300',
                  confirmed:     'bg-blue-950 text-blue-300',
                  in_production: 'bg-purple-950 text-purple-300',
                  shipped:       'bg-cyan-950 text-cyan-300',
                  delivered:     'bg-emerald-950 text-emerald-300',
                  cancelled:     'bg-red-950 text-red-400',
                };
                var statusLabel = {
                  pending:       'Oczekujące',
                  confirmed:     'Potwierdzone',
                  in_production: 'W produkcji',
                  shipped:       'Wysłane',
                  delivered:     'Dostarczone',
                  cancelled:     'Anulowane',
                };
              %>
              <% orders.forEach(function(order, i) { %>
              <tr class="border-b border-white/5 hover:bg-white/[0.03] transition-colors <%= i % 2 === 1 ? 'bg-white/[0.015]' : '' %>">
                <td class="px-4 py-3 font-mono text-xs text-amber-300 whitespace-nowrap">
                  <a href="/orders/<%= order.id %>" class="hover:text-amber-200"><%= order.order_number %></a>
                </td>
                <td class="px-4 py-3 text-neutral-400 whitespace-nowrap text-xs">
                  <%= fmtDate(order.created_at) %>
                </td>
                <td class="px-4 py-3 text-neutral-200 max-w-[160px] truncate">
                  <%= order.customer_name %>
                  <% if (order.company_name) { %>
                  <div class="text-xs text-neutral-500 truncate"><%= order.company_name %></div>
                  <% } %>
                </td>
                <td class="px-4 py-3 text-neutral-400 max-w-[180px] truncate text-xs">
                  <a href="mailto:<%= order.customer_email %>" class="hover:text-white transition-colors"><%= order.customer_email %></a>
                </td>
                <td class="px-4 py-3 text-neutral-400 text-xs uppercase"><%= order.country || '—' %></td>
                <td class="px-4 py-3 text-neutral-400 text-xs"><%= order.shipping_method || '—' %></td>
                <td class="px-4 py-3 text-right text-neutral-200 whitespace-nowrap font-medium">
                  <%= parseFloat(order.total_brutto).toFixed(2) %> <span class="text-neutral-500 text-xs"><%= order.currency %></span>
                </td>
                <td class="px-4 py-3">
                  <span class="px-2 py-0.5 rounded text-xs font-medium <%= statusBadge[order.status] || 'bg-neutral-800 text-neutral-400' %>">
                    <%= statusLabel[order.status] || order.status %>
                  </span>
                </td>
                <td class="px-4 py-3">
                  <a href="/orders/<%= order.id %>" class="text-xs text-blue-400 hover:text-blue-300 transition-colors">Szczegóły &rarr;</a>
                </td>
              </tr>
              <% }); %>
            <% } else { %>
            <tr>
              <td colspan="9" class="px-4 py-12 text-center text-neutral-600">Brak zamówień.</td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  </main>

  <script>
    function fmtDate(d) {
      if (!d) return '—';
      const dt = new Date(d);
      return dt.toLocaleDateString('pl-PL') + ' ' + dt.toLocaleTimeString('pl-PL', { hour: '2-digit', minute: '2-digit' });
    }
  </script>

</body>
</html>
