<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AEJaCA Admin — Filamenty</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            neutral: { 950: '#0a0a0a' }
          }
        }
      }
    }
  </script>
</head>
<body class="bg-neutral-950 min-h-screen text-neutral-100">

  <header class="bg-neutral-900 border-b border-white/10 px-6 py-3 flex items-center justify-between">
    <div class="flex items-center gap-6">
      <span class="text-lg font-bold text-white">AEJaCA <span class="text-amber-400">Admin</span></span>
      <nav class="flex gap-4 text-sm">
        <a href="/dashboard" class="text-neutral-400 hover:text-white transition-colors">Dashboard</a>
        <a href="/analytics" class="text-neutral-400 hover:text-white transition-colors">Analytics</a>
        <a href="/leads" class="text-neutral-400 hover:text-white transition-colors">Leads</a>
        <a href="/subscribers" class="text-neutral-400 hover:text-white transition-colors">Subscribers</a>
        <a href="/conversations" class="text-neutral-400 hover:text-white transition-colors">Chat</a>
        <a href="/email-threads" class="text-neutral-400 hover:text-white transition-colors">Email</a>
        <a href="/laser-matrix" class="text-neutral-400 hover:text-white transition-colors">Laser Matrix</a>
        <a href="/gemstone-prices" class="text-neutral-400 hover:text-white transition-colors">Gems</a>
        <a href="/filaments" class="text-white font-medium border-b border-amber-400 pb-0.5">Filamenty<% if (pendingContributions > 0) { %> <span class="text-amber-400">(<%= pendingContributions %>)</span><% } %></a>
      </nav>
    </div>
    <div class="flex items-center gap-3">
      <img src="<%= user.photo %>" class="w-7 h-7 rounded-full" alt="" />
      <span class="text-sm text-neutral-400"><%= user.name %></span>
      <a href="/logout" class="text-xs text-red-400 hover:text-red-300 transition-colors">Logout</a>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-6 py-8">

    <!-- Flash banner -->
    <% if (filters.flash === 'created') { %>
    <div class="mb-5 px-4 py-3 bg-emerald-950 border border-emerald-700/50 text-emerald-300 rounded-lg text-sm">
      &#10003; Typ #<%= filters.id %> dodany
    </div>
    <% } else if (filters.flash === 'updated') { %>
    <div class="mb-5 px-4 py-3 bg-emerald-950 border border-emerald-700/50 text-emerald-300 rounded-lg text-sm">
      &#10003; Typ #<%= filters.id %> zaktualizowany
    </div>
    <% } else if (filters.flash === 'deleted') { %>
    <div class="mb-5 px-4 py-3 bg-neutral-800 border border-white/10 text-neutral-400 rounded-lg text-sm">
      &#128465; Typ usunięty
    </div>
    <% } %>

    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
      <h2 class="text-xl font-semibold text-white">Filamenty</h2>
      <div class="flex items-center gap-3">
        <a href="/filaments/contributions" class="inline-flex items-center gap-2 px-4 py-2 bg-neutral-800 hover:bg-neutral-700 text-neutral-200 text-sm font-medium rounded-lg transition-colors">
          Zgłoszenia<% if (pendingContributions > 0) { %> <span class="bg-amber-500 text-neutral-950 text-xs font-bold px-1.5 py-0.5 rounded-full"><%= pendingContributions %></span><% } %>
        </a>
        <a href="/filaments/new" class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-lg transition-colors">
          + Nowy typ
        </a>
      </div>
    </div>

    <!-- Stats row -->
    <div class="flex flex-wrap gap-3 mb-6">
      <div class="bg-neutral-900 border border-white/10 rounded-xl px-5 py-3 flex items-center gap-3">
        <span class="text-neutral-500 text-sm">Łącznie</span>
        <span class="text-2xl font-bold text-amber-400"><%= total %></span>
        <span class="text-neutral-500 text-xs">typów</span>
      </div>
      <% if (catStats && catStats.length > 0) { %>
        <% var catColors = { standard: 'text-blue-300 bg-blue-950', engineering: 'text-purple-300 bg-purple-950', flexible: 'text-emerald-300 bg-emerald-950', specialty: 'text-amber-300 bg-amber-950' }; %>
        <% catStats.forEach(function(s) { %>
        <div class="bg-neutral-900 border border-white/10 rounded-xl px-4 py-3 flex items-center gap-2">
          <span class="text-xs px-2 py-0.5 rounded font-medium <%= catColors[s.category] || 'text-neutral-300 bg-neutral-800' %> uppercase"><%= s.category %></span>
          <span class="text-lg font-semibold text-white"><%= s.count %></span>
        </div>
        <% }); %>
      <% } %>
    </div>

    <!-- Filter bar -->
    <form method="GET" action="/filaments" class="flex flex-wrap gap-3 mb-6">
      <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Szukaj nazwy lub ID..." class="bg-neutral-800 border border-white/10 text-neutral-300 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50 w-56" />
      <select name="category" class="bg-neutral-800 border border-white/10 text-neutral-300 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50">
        <option value="">Wszystkie kategorie</option>
        <option value="standard" <%= filters.category === 'standard' ? 'selected' : '' %>>Standard</option>
        <option value="engineering" <%= filters.category === 'engineering' ? 'selected' : '' %>>Engineering</option>
        <option value="flexible" <%= filters.category === 'flexible' ? 'selected' : '' %>>Flexible</option>
        <option value="specialty" <%= filters.category === 'specialty' ? 'selected' : '' %>>Specialty</option>
      </select>
      <button type="submit" class="px-4 py-2 bg-amber-500 hover:bg-amber-400 text-neutral-950 text-sm font-medium rounded-lg transition-colors">Filtruj</button>
      <a href="/filaments" class="px-4 py-2 bg-neutral-800 hover:bg-neutral-700 text-neutral-400 hover:text-white text-sm rounded-lg transition-colors">Wyczyść</a>
    </form>

    <!-- Table -->
    <div class="bg-neutral-900 border border-white/10 rounded-xl overflow-hidden mb-6">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/10 text-neutral-500 text-xs uppercase tracking-wider">
              <th class="px-4 py-3 text-left">ID</th>
              <th class="px-4 py-3 text-left">Nazwa</th>
              <th class="px-4 py-3 text-left">Kategoria</th>
              <th class="px-4 py-3 text-left">Trudność</th>
              <th class="px-4 py-3 text-right">Dysza °C</th>
              <th class="px-4 py-3 text-right">Łoże °C</th>
              <th class="px-4 py-3 text-right">Wyłączenie zamk.</th>
              <th class="px-4 py-3 text-right">Cena/kg</th>
              <th class="px-4 py-3 text-right"></th>
            </tr>
          </thead>
          <tbody>
            <% if (rows && rows.length > 0) { %>
              <% var catColors = { standard: 'text-blue-300 bg-blue-950', engineering: 'text-purple-300 bg-purple-950', flexible: 'text-emerald-300 bg-emerald-950', specialty: 'text-amber-300 bg-amber-950' }; %>
              <% var enclosureLabel = { no: '—', recommended: 'zalec.', required: 'wymagana' }; %>
              <% rows.forEach(function(row, i) { %>
              <tr class="border-b border-white/5 hover:bg-white/[0.03] transition-colors group <%= i % 2 === 1 ? 'bg-white/[0.015]' : '' %>">
                <td class="px-4 py-3 text-neutral-600 text-xs font-mono"><%= row.id %></td>
                <td class="px-4 py-3">
                  <div class="font-medium text-neutral-200"><%= row.name || '—' %></div>
                  <div class="text-xs text-neutral-600 font-mono"><%= row.type_id || '' %></div>
                  <% if (!row.is_active) { %>
                  <span class="text-xs text-red-500">nieaktywny</span>
                  <% } %>
                </td>
                <td class="px-4 py-3">
                  <% if (row.category) { %>
                  <span class="px-2 py-0.5 rounded text-xs font-medium uppercase <%= catColors[row.category] || 'text-neutral-300 bg-neutral-800' %>"><%= row.category %></span>
                  <% } else { %>
                  <span class="text-neutral-600">—</span>
                  <% } %>
                </td>
                <td class="px-4 py-3">
                  <% if (row.difficulty) { %>
                  <span class="text-amber-400 tracking-widest text-xs"><%= '●'.repeat(row.difficulty) %><%= '○'.repeat(5 - row.difficulty) %></span>
                  <% } else { %>
                  <span class="text-neutral-600">—</span>
                  <% } %>
                </td>
                <td class="px-4 py-3 text-right text-neutral-300 whitespace-nowrap text-xs">
                  <% if (row.nozzle_min || row.nozzle_max) { %><%= row.nozzle_min || '?' %>–<%= row.nozzle_max || '?' %>°C<% } else { %><span class="text-neutral-600">—</span><% } %>
                </td>
                <td class="px-4 py-3 text-right text-neutral-400 text-xs whitespace-nowrap">
                  <% if (row.bed_min || row.bed_max) { %><%= row.bed_min || '?' %>–<%= row.bed_max || '?' %>°C<% } else { %><span class="text-neutral-600">—</span><% } %>
                </td>
                <td class="px-4 py-3 text-right text-neutral-400 text-xs whitespace-nowrap">
                  <%= enclosureLabel[row.enclosure] || row.enclosure || '—' %>
                </td>
                <td class="px-4 py-3 text-right text-neutral-300 text-xs whitespace-nowrap">
                  <% if (row.price_per_kg) { %><%= row.price_per_kg %> zł<% } else { %><span class="text-neutral-600">—</span><% } %>
                </td>
                <td class="px-4 py-3 whitespace-nowrap text-right">
                  <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                    <a href="/filaments/<%= row.id %>/edit" class="text-amber-400 hover:text-amber-300 text-sm transition-colors" title="Edytuj">&#9998;</a>
                    <a href="/filaments/<%= row.id %>/brands" class="text-blue-400 hover:text-blue-300 text-xs transition-colors whitespace-nowrap" title="Marki">Marki (<%= row.brand_count %>)</a>
                    <form method="POST" action="/filaments/<%= row.id %>/delete" onsubmit="return confirm('Usunąć typ #<%= row.id %> (<%= (row.name || '').replace(/'/g, '') %>)? Tej operacji nie można cofnąć.')">
                      <button type="submit" class="text-red-500 hover:text-red-400 text-sm transition-colors" title="Usuń">&#128465;</button>
                    </form>
                  </div>
                </td>
              </tr>
              <% }); %>
            <% } else { %>
            <tr>
              <td colspan="9" class="px-4 py-12 text-center text-neutral-600">Brak typów filamentów. <a href="/filaments/new" class="text-amber-400 hover:text-amber-300">Dodaj pierwszy.</a></td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-between">
      <span class="text-sm text-neutral-500">
        <% var from = (page - 1) * 50 + 1; var to = Math.min(page * 50, total); %>
        <% if (total > 0) { %>Showing <%= from %>–<%= to %> of <%= total %><% } else { %>Brak wyników<% } %>
      </span>
      <% if (pages > 1) { %>
      <div class="flex gap-2">
        <% if (page > 1) { %>
        <a href="/filaments?page=<%= page - 1 %>&search=<%= filters.search || '' %>&category=<%= filters.category || '' %>" class="px-4 py-2 bg-neutral-900 border border-white/10 rounded-lg text-sm text-neutral-300 hover:text-white hover:border-white/20 transition-colors">
          &larr; Prev
        </a>
        <% } else { %>
        <span class="px-4 py-2 bg-neutral-900 border border-white/5 rounded-lg text-sm text-neutral-700 cursor-not-allowed">&larr; Prev</span>
        <% } %>
        <% if (page < pages) { %>
        <a href="/filaments?page=<%= page + 1 %>&search=<%= filters.search || '' %>&category=<%= filters.category || '' %>" class="px-4 py-2 bg-neutral-900 border border-white/10 rounded-lg text-sm text-neutral-300 hover:text-white hover:border-white/20 transition-colors">
          Next &rarr;
        </a>
        <% } else { %>
        <span class="px-4 py-2 bg-neutral-900 border border-white/5 rounded-lg text-sm text-neutral-700 cursor-not-allowed">Next &rarr;</span>
        <% } %>
      </div>
      <% } %>
    </div>

  </main>

</body>
</html>
