<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AEJaCA Admin — Error</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            neutral: { 950: '#0a0a0a' }
          }
        }
      }
    }
  </script>
</head>
<body class="bg-neutral-950 min-h-screen flex items-center justify-center">
  <div class="w-full max-w-md px-6 text-center">

    <div class="mb-8">
      <span class="text-lg font-bold text-white">AEJ<span class="text-amber-400">a</span>CA</span>
    </div>

    <div class="bg-neutral-900 border border-red-900/50 rounded-2xl p-8 mb-6">
      <div class="w-12 h-12 bg-red-950 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
        </svg>
      </div>
      <h1 class="text-xl font-semibold text-white mb-3">Error</h1>
      <p class="text-neutral-400 text-sm leading-relaxed"><%= message || 'An unexpected error occurred.' %></p>
    </div>

    <a
      href="/dashboard"
      class="inline-flex items-center gap-2 px-5 py-2.5 bg-neutral-800 hover:bg-neutral-700 border border-white/10 text-neutral-200 text-sm rounded-lg transition-colors"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      Back to Dashboard
    </a>

  </div>
</body>
</html>
