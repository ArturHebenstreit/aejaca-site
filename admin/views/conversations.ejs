<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AEJaCA Admin — Chat Conversations</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            neutral: { 950: '#0a0a0a' }
          }
        }
      }
    }
  </script>
</head>
<body class="bg-neutral-950 min-h-screen text-neutral-100">

  <header class="bg-neutral-900 border-b border-white/10 px-6 py-3 flex items-center justify-between">
    <div class="flex items-center gap-6">
      <span class="text-lg font-bold text-white">AEJaCA <span class="text-amber-400">Admin</span></span>
      <nav class="flex gap-4 text-sm">
        <a href="/dashboard" class="text-neutral-400 hover:text-white transition-colors">Dashboard</a>
        <a href="/analytics" class="text-neutral-400 hover:text-white transition-colors">Analytics</a>
        <a href="/leads" class="text-neutral-400 hover:text-white transition-colors">Leads</a>
        <a href="/subscribers" class="text-neutral-400 hover:text-white transition-colors">Subscribers</a>
        <a href="/conversations" class="text-white font-medium border-b border-emerald-400 pb-0.5">Chat</a>
      </nav>
    </div>
    <div class="flex items-center gap-3">
      <img src="<%= user.photo %>" class="w-7 h-7 rounded-full" alt="" />
      <span class="text-sm text-neutral-400"><%= user.name %></span>
      <a href="/logout" class="text-xs text-red-400 hover:text-red-300 transition-colors">Logout</a>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-6 py-8">

    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl font-semibold text-white">Chat Conversations</h2>
      <div class="flex items-center gap-3 flex-wrap">
        <div class="flex gap-2 text-xs">
          <a href="/conversations" class="px-3 py-1.5 rounded-full <%= filter === 'all' ? 'bg-emerald-950 text-emerald-300 border border-emerald-400/30' : 'bg-neutral-800 text-neutral-400 border border-white/10 hover:text-white' %> transition-colors">
            All (<%= stats.total %>)
          </a>
          <a href="/conversations?filter=hot" class="px-3 py-1.5 rounded-full <%= filter === 'hot' ? 'bg-red-950 text-red-300 border border-red-400/30' : 'bg-neutral-800 text-neutral-400 border border-white/10 hover:text-white' %> transition-colors">
            Hot Leads (<%= stats.hot %>)
          </a>
        </div>
        <span class="text-xs text-neutral-500">Today: <%= stats.today %></span>
        <form method="POST" action="/conversations/bulk-delete" onsubmit="return confirmBulkDelete(this)">
          <div class="flex items-center gap-2">
            <select name="older_than_days" class="bg-neutral-800 border border-white/10 text-neutral-400 text-xs rounded px-2 py-1.5">
              <option value="3">starsze niż 3d</option>
              <option value="7">starsze niż 7d</option>
              <option value="30" selected>starsze niż 30d</option>
              <option value="90">starsze niż 90d</option>
              <option value="all">⚠ wyczyść wszystko</option>
            </select>
            <label class="flex items-center gap-1.5 cursor-pointer select-none" title="Uwaga: usunie też rozmowy oznaczone jako Hot Lead">
              <input type="checkbox" name="include_hot" value="1"
                class="w-3.5 h-3.5 accent-red-500 cursor-pointer"
                onchange="this.closest('form').querySelector('.hot-warn').classList.toggle('hidden', !this.checked)" />
              <span class="text-xs text-neutral-500">+ hot</span>
            </label>
            <span class="hot-warn hidden text-xs text-red-400 font-medium">!</span>
            <button type="submit" class="px-2 py-1.5 bg-red-950 border border-red-900/50 text-red-400 hover:text-red-300 text-xs rounded transition-colors">Usuń stare</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Conversations table -->
    <div class="bg-neutral-900 border border-white/10 rounded-xl overflow-hidden mb-6">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/10 text-neutral-500 text-xs uppercase tracking-wider">
              <th class="px-4 py-3 text-left">Date</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-neutral-400 uppercase tracking-wider">Kraj</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-neutral-400 uppercase tracking-wider">Sesja</th>
              <th class="px-4 py-3 text-left">Lang</th>
              <th class="px-4 py-3 text-left">User Message</th>
              <th class="px-4 py-3 text-left">AI Response</th>
              <th class="px-4 py-3 text-center">Msgs</th>
              <th class="px-4 py-3 text-center">Hot</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-neutral-400 uppercase tracking-wider"></th>
            </tr>
          </thead>
          <tbody>
            <% if (conversations && conversations.length > 0) { %>
              <% conversations.forEach(function(c) { %>
              <tr class="border-b border-white/5 hover:bg-white/[0.02] transition-colors group">
                <td class="px-4 py-3 text-neutral-400 whitespace-nowrap text-xs">
                  <%= new Date(c.created_at).toLocaleDateString('pl-PL') %><br/>
                  <span class="text-neutral-600"><%= new Date(c.created_at).toLocaleTimeString('pl-PL', { hour: '2-digit', minute: '2-digit' }) %></span>
                </td>
                <td class="px-4 py-3 whitespace-nowrap text-sm text-neutral-300">
                  <%= c.country || '—' %>
                </td>
                <td class="px-4 py-3 whitespace-nowrap text-xs font-mono text-neutral-500" title="<%= c.session_id || '' %>">
                  <%= c.session_id ? c.session_id.slice(0, 8) : '—' %>
                </td>
                <td class="px-4 py-3">
                  <span class="px-2 py-0.5 bg-blue-950 text-blue-300 rounded text-xs font-medium uppercase">
                    <%= c.lang || '?' %>
                  </span>
                </td>
                <td class="px-4 py-3 text-neutral-200 text-xs max-w-[280px]">
                  <div class="line-clamp-3 whitespace-pre-wrap"><%= c.last_user_message || '—' %></div>
                </td>
                <td class="px-4 py-3 text-neutral-400 text-xs max-w-[320px]">
                  <div class="line-clamp-3 whitespace-pre-wrap"><%= c.assistant_response ? c.assistant_response.slice(0, 200) : '—' %></div>
                </td>
                <td class="px-4 py-3 text-center text-neutral-300 text-xs">
                  <%= c.messages_count %>
                </td>
                <td class="px-4 py-3 text-center">
                  <% if (c.hot_lead) { %>
                    <span class="px-2 py-0.5 bg-red-950 text-red-300 rounded text-xs font-medium">HOT</span>
                  <% } else { %>
                    <span class="text-neutral-700">—</span>
                  <% } %>
                </td>
                <td class="px-4 py-3 whitespace-nowrap text-right">
                  <form method="POST" action="/conversations/<%= c.id %>/delete">
                    <button type="submit" class="opacity-0 group-hover:opacity-100 text-red-500 hover:text-red-400 transition-all px-1 text-base leading-none" title="Usuń">✕</button>
                  </form>
                </td>
              </tr>
              <% }); %>
            <% } else { %>
            <tr>
              <td colspan="9" class="px-4 py-8 text-center text-neutral-600">No conversations yet.</td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Pagination -->
    <% if (pages > 1) { %>
    <div class="flex items-center justify-center gap-2 text-sm">
      <% if (page > 1) { %>
        <a href="/conversations?page=<%= page - 1 %>&filter=<%= filter %>" class="px-3 py-1.5 rounded bg-neutral-800 text-neutral-300 hover:text-white transition-colors">&larr; Prev</a>
      <% } %>
      <span class="px-3 py-1.5 text-neutral-500">Page <%= page %> of <%= pages %></span>
      <% if (page < pages) { %>
        <a href="/conversations?page=<%= page + 1 %>&filter=<%= filter %>" class="px-3 py-1.5 rounded bg-neutral-800 text-neutral-300 hover:text-white transition-colors">Next &rarr;</a>
      <% } %>
    </div>
    <% } %>

  </main>

  <script>
    function confirmBulkDelete(form) {
      const includeHot = form.querySelector('[name="include_hot"]').checked;
      const val = form.querySelector('[name="older_than_days"]').value;
      if (val === 'all') {
        if (includeHot) return confirm('UWAGA: Usunąć WSZYSTKIE rozmowy włącznie z HOT LEADAMI?\n\nTej operacji nie można cofnąć.');
        return confirm('Usunąć WSZYSTKIE rozmowy (hot leady zostaną)?\n\nTej operacji nie można cofnąć.');
      }
      if (includeHot) return confirm(`UWAGA: Usunąć WSZYSTKIE rozmowy (w tym HOT LEADY) starsze niż ${val} dni?\n\nTej operacji nie można cofnąć.`);
      return confirm(`Usunąć rozmowy (bez hot leadów) starsze niż ${val} dni?`);
    }
  </script>
</body>
</html>
