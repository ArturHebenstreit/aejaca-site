<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AEJaCA Admin — <%= row ? 'Edytuj #' + row.id + ' — ' + (row.name || row.type_id) : 'Nowy typ filaменту' %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            neutral: { 950: '#0a0a0a' }
          }
        }
      }
    }
  </script>
</head>
<body class="bg-neutral-950 min-h-screen text-neutral-100">

  <header class="bg-neutral-900 border-b border-white/10 px-6 py-3 flex items-center justify-between">
    <div class="flex items-center gap-6">
      <span class="text-lg font-bold text-white">AEJaCA <span class="text-amber-400">Admin</span></span>
      <nav class="flex gap-4 text-sm">
        <a href="/dashboard" class="text-neutral-400 hover:text-white transition-colors">Dashboard</a>
        <a href="/analytics" class="text-neutral-400 hover:text-white transition-colors">Analytics</a>
        <a href="/leads" class="text-neutral-400 hover:text-white transition-colors">Leads</a>
        <a href="/subscribers" class="text-neutral-400 hover:text-white transition-colors">Subscribers</a>
        <a href="/conversations" class="text-neutral-400 hover:text-white transition-colors">Chat</a>
        <a href="/laser-matrix" class="text-neutral-400 hover:text-white transition-colors">Laser Matrix</a>
        <a href="/gemstone-prices" class="text-neutral-400 hover:text-white transition-colors">Gems</a>
        <a href="/filaments" class="text-white font-medium border-b border-amber-400 pb-0.5">Filamenty<% if (typeof pendingContributions !== 'undefined' && pendingContributions > 0) { %> <span class="text-amber-400">(<%= pendingContributions %>)</span><% } %></a>
      </nav>
    </div>
    <div class="flex items-center gap-3">
      <img src="<%= user.photo %>" class="w-7 h-7 rounded-full" alt="" />
      <span class="text-sm text-neutral-400"><%= user.name %></span>
      <a href="/logout" class="text-xs text-red-400 hover:text-red-300 transition-colors">Logout</a>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-6 py-8">

    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-neutral-500 mb-6">
      <a href="/filaments" class="hover:text-amber-400 transition-colors">&larr; Filamenty</a>
      <span>&rsaquo;</span>
      <% if (row) { %>
        <span class="text-neutral-300">Edytuj #<%= row.id %></span>
      <% } else { %>
        <span class="text-neutral-300">Nowy typ</span>
      <% } %>
    </div>

    <% if (flash === 'created') { %>
    <div class="mb-5 px-4 py-3 bg-emerald-950 border border-emerald-700/50 text-emerald-300 rounded-lg text-sm">
      &#10003; Typ dodany pomyślnie
    </div>
    <% } %>

    <form method="POST" action="<%= row ? '/filaments/' + row.id + '/update' : '/filaments/create' %>" class="space-y-8">

      <!-- SEKCJA 1: Identyfikacja -->
      <fieldset class="bg-neutral-900 border border-white/10 rounded-xl p-6">
        <legend class="text-sm font-semibold text-blue-400 uppercase tracking-wider px-2 mb-4">Sekcja 1 — Identyfikacja</legend>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">type_id</label>
            <input type="text" name="type_id" value="<%= row ? (row.type_id || '') : '' %>"
              placeholder="np. PLA, PETG, TPU95A"
              <%= row ? 'readonly class="w-full bg-neutral-700 border border-white/10 text-neutral-500 text-sm rounded-lg px-3 py-2 cursor-not-allowed"' : 'class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50"' %> />
            <% if (row) { %><p class="text-xs text-neutral-600 mt-1">Nie można zmieniać po utworzeniu</p><% } %>
          </div>

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Nazwa</label>
            <input type="text" name="name" value="<%= row ? (row.name || '') : '' %>"
              placeholder="np. PLA Standard"
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50" />
          </div>

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Kategoria</label>
            <select name="category" class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50">
              <option value="">— wybierz —</option>
              <option value="standard" <%= (row && row.category === 'standard') ? 'selected' : '' %>>Standard</option>
              <option value="engineering" <%= (row && row.category === 'engineering') ? 'selected' : '' %>>Engineering</option>
              <option value="flexible" <%= (row && row.category === 'flexible') ? 'selected' : '' %>>Flexible</option>
              <option value="specialty" <%= (row && row.category === 'specialty') ? 'selected' : '' %>>Specialty</option>
            </select>
          </div>

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Kolejność sortowania</label>
            <input type="number" name="sort_order" value="<%= row ? (row.sort_order != null ? row.sort_order : 0) : 0 %>"
              placeholder="0"
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50" />
          </div>

        </div>
      </fieldset>

      <!-- SEKCJA 2: Temperatury -->
      <fieldset class="bg-neutral-900 border border-white/10 rounded-xl p-6">
        <legend class="text-sm font-semibold text-amber-400 uppercase tracking-wider px-2 mb-4">Sekcja 2 — Temperatury</legend>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Dysza min (°C)</label>
            <input type="number" name="nozzle_min" value="<%= row ? (row.nozzle_min || '') : '' %>"
              placeholder="np. 190"
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50" />
          </div>

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Dysza max (°C)</label>
            <input type="number" name="nozzle_max" value="<%= row ? (row.nozzle_max || '') : '' %>"
              placeholder="np. 230"
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50" />
          </div>

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Łoże min (°C)</label>
            <input type="number" name="bed_min" value="<%= row ? (row.bed_min || '') : '' %>"
              placeholder="np. 40"
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50" />
          </div>

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Łoże max (°C)</label>
            <input type="number" name="bed_max" value="<%= row ? (row.bed_max || '') : '' %>"
              placeholder="np. 60"
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50" />
          </div>

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Odporność temp. (°C)</label>
            <input type="number" name="temp_resistance" value="<%= row ? (row.temp_resistance || '') : '' %>"
              placeholder="np. 60"
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50" />
          </div>

        </div>
      </fieldset>

      <!-- SEKCJA 3: Parametry druku -->
      <fieldset class="bg-neutral-900 border border-white/10 rounded-xl p-6">
        <legend class="text-sm font-semibold text-emerald-400 uppercase tracking-wider px-2 mb-4">Sekcja 3 — Parametry druku</legend>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Prędkość min (mm/s)</label>
            <input type="number" name="speed_min" value="<%= row ? (row.speed_min || '') : '' %>"
              placeholder="np. 30"
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50" />
          </div>

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Prędkość max (mm/s)</label>
            <input type="number" name="speed_max" value="<%= row ? (row.speed_max || '') : '' %>"
              placeholder="np. 100"
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50" />
          </div>

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Warstwa min (mm)</label>
            <input type="number" step="0.01" name="layer_min" value="<%= row ? (row.layer_min || '') : '' %>"
              placeholder="np. 0.1"
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50" />
          </div>

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Warstwa max (mm)</label>
            <input type="number" step="0.01" name="layer_max" value="<%= row ? (row.layer_max || '') : '' %>"
              placeholder="np. 0.3"
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50" />
          </div>

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Retrakcja min (mm)</label>
            <input type="number" step="0.1" name="retraction_min" value="<%= row ? (row.retraction_min || '') : '' %>"
              placeholder="np. 1"
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50" />
          </div>

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Retrakcja max (mm)</label>
            <input type="number" step="0.1" name="retraction_max" value="<%= row ? (row.retraction_max || '') : '' %>"
              placeholder="np. 6"
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50" />
          </div>

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Chłodzenie (%)</label>
            <input type="number" name="cooling" value="<%= row ? (row.cooling || '') : '' %>"
              placeholder="np. 100"
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50" />
          </div>

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Obudowa</label>
            <select name="enclosure" class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50">
              <option value="">— wybierz —</option>
              <option value="no" <%= (row && row.enclosure === 'no') ? 'selected' : '' %>>Nie wymagana</option>
              <option value="recommended" <%= (row && row.enclosure === 'recommended') ? 'selected' : '' %>>Zalecana</option>
              <option value="required" <%= (row && row.enclosure === 'required') ? 'selected' : '' %>>Wymagana</option>
            </select>
          </div>

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Trudność (1–5)</label>
            <select name="difficulty" class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50">
              <option value="">— wybierz —</option>
              <% [1,2,3,4,5].forEach(function(d) { %>
              <option value="<%= d %>" <%= (row && row.difficulty == d) ? 'selected' : '' %>><%= d %> — <%= ['Bardzo łatwy','Łatwy','Średni','Trudny','Bardzo trudny'][d-1] %></option>
              <% }); %>
            </select>
          </div>

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Gęstość (g/cm³)</label>
            <input type="number" step="0.01" name="density" value="<%= row ? (row.density || '') : '' %>"
              placeholder="np. 1.24"
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50" />
          </div>

        </div>
      </fieldset>

      <!-- SEKCJA 4: Właściwości -->
      <fieldset class="bg-neutral-900 border border-white/10 rounded-xl p-6">
        <legend class="text-sm font-semibold text-purple-400 uppercase tracking-wider px-2 mb-4">Sekcja 4 — Właściwości</legend>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Cena/kg (PLN)</label>
            <input type="number" step="0.01" name="price_per_kg" value="<%= row ? (row.price_per_kg || '') : '' %>"
              placeholder="np. 89.90"
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50" />
          </div>

          <div>
            <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Właściwości (props)</label>
            <textarea name="props" rows="3" placeholder="UV_resistant, food_safe, flexible, conductive..."
              class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50 resize-y"><%= row && row.props ? (Array.isArray(row.props) ? row.props.join(', ') : row.props) : '' %></textarea>
            <p class="text-xs text-neutral-600 mt-1">Wartości oddzielone przecinkami</p>
          </div>

        </div>
      </fieldset>

      <!-- SEKCJA 5: Teksty PL/EN/DE -->
      <fieldset class="bg-neutral-900 border border-white/10 rounded-xl p-6">
        <legend class="text-sm font-semibold text-cyan-400 uppercase tracking-wider px-2 mb-4">Sekcja 5 — Teksty PL / EN / DE</legend>

        <div class="mb-4">
          <p class="text-xs text-neutral-500 mb-3">Zastosowania (uses)</p>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div>
              <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Zastosowania PL</label>
              <textarea name="uses_pl" rows="3" placeholder="Prototypy, elementy dekoracyjne..."
                class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50 resize-y"><%= row ? (row.uses_pl || '') : '' %></textarea>
            </div>
            <div>
              <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Zastosowania EN</label>
              <textarea name="uses_en" rows="3" placeholder="Prototypes, decorative parts..."
                class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50 resize-y"><%= row ? (row.uses_en || '') : '' %></textarea>
            </div>
            <div>
              <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Zastosowania DE</label>
              <textarea name="uses_de" rows="3" placeholder="Prototypen, Dekorteile..."
                class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50 resize-y"><%= row ? (row.uses_de || '') : '' %></textarea>
            </div>
          </div>
        </div>

        <div>
          <p class="text-xs text-neutral-500 mb-3">Uwagi (notes)</p>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div>
              <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Uwagi PL</label>
              <textarea name="notes_pl" rows="3" placeholder="Uwagi techniczne po polsku..."
                class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50 resize-y"><%= row ? (row.notes_pl || '') : '' %></textarea>
            </div>
            <div>
              <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Uwagi EN</label>
              <textarea name="notes_en" rows="3" placeholder="Technical notes in English..."
                class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50 resize-y"><%= row ? (row.notes_en || '') : '' %></textarea>
            </div>
            <div>
              <label class="block text-xs font-medium text-neutral-400 uppercase tracking-wider mb-1">Uwagi DE</label>
              <textarea name="notes_de" rows="3" placeholder="Technische Hinweise auf Deutsch..."
                class="w-full bg-neutral-800 border border-white/10 text-neutral-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-amber-400/50 resize-y"><%= row ? (row.notes_de || '') : '' %></textarea>
            </div>
          </div>
        </div>
      </fieldset>

      <!-- SEKCJA 6: Metadane -->
      <fieldset class="bg-neutral-900 border border-white/10 rounded-xl p-6">
        <legend class="text-sm font-semibold text-rose-400 uppercase tracking-wider px-2 mb-4">Sekcja 6 — Metadane</legend>
        <div class="flex items-center gap-3">
          <input type="checkbox" name="is_active" id="is_active" <%= (row ? row.is_active : true) ? 'checked' : '' %> class="w-4 h-4 rounded border-white/20 bg-neutral-800 text-amber-400 focus:ring-amber-400/30" />
          <label for="is_active" class="text-sm text-neutral-300">Aktywny (widoczny w API)</label>
        </div>
        <% if (row) { %>
        <div class="mt-4 text-xs text-neutral-600">
          <% if (row.updated_at) { %>Ostatnia zmiana: <%= new Date(row.updated_at).toLocaleString('pl-PL') %><% } %>
          <% if (row.updated_by) { %> przez <%= row.updated_by %><% } %>
        </div>
        <% } %>
      </fieldset>

      <!-- Actions -->
      <div class="flex items-center justify-between pt-2">
        <a href="/filaments" class="text-sm text-neutral-400 hover:text-white transition-colors">&larr; Wróć do listy</a>
        <div class="flex items-center gap-3">
          <% if (row) { %>
          <form method="POST" action="/filaments/<%= row.id %>/delete" onsubmit="return confirm('Usunąć typ #<%= row.id %> (<%= (row.name || row.type_id || '').replace(/\'/g, '') %>)? Tej operacji nie można cofnąć.')">
            <button type="submit" class="px-4 py-2 bg-red-950 border border-red-900/50 text-red-400 hover:text-red-300 text-sm rounded-lg transition-colors">
              &#128465; Usuń typ
            </button>
          </form>
          <% } %>
          <button type="submit" class="px-6 py-2 bg-amber-500 hover:bg-amber-400 text-neutral-950 text-sm font-medium rounded-lg transition-colors">
            &#128190; Zapisz
          </button>
        </div>
      </div>

    </form>

    <% if (row) { %>
    <div class="mt-6 pt-6 border-t border-white/10">
      <a href="/filaments/<%= row.id %>/brands" class="text-sm text-blue-400 hover:text-blue-300 transition-colors">
        &rarr; Zarządzaj markami dla tego typu
      </a>
    </div>
    <% } %>

  </main>

</body>
</html>
