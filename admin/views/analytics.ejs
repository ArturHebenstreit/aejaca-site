<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AEJaCA Admin — Analytics</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config = { theme: { extend: { colors: { neutral: { 950: '#0a0a0a' } } } } }</script>
</head>
<body class="bg-neutral-950 min-h-screen text-neutral-100">

  <header class="bg-neutral-900 border-b border-white/10 px-6 py-3 flex items-center justify-between">
    <div class="flex items-center gap-6">
      <span class="text-lg font-bold text-white">AEJaCA <span class="text-amber-400">Admin</span></span>
      <nav class="flex gap-4 text-sm">
        <a href="/dashboard" class="text-neutral-400 hover:text-white transition-colors">Dashboard</a>
        <a href="/analytics" class="text-white font-medium border-b border-emerald-400 pb-0.5">Analytics</a>
        <a href="/leads" class="text-neutral-400 hover:text-white transition-colors">Leads</a>
        <a href="/subscribers" class="text-neutral-400 hover:text-white transition-colors">Subscribers</a>
        <a href="/conversations" class="text-neutral-400 hover:text-white transition-colors">Chat</a>
        <a href="/email-threads" class="text-neutral-400 hover:text-white transition-colors">Email</a>
        <a href="/laser-matrix" class="text-neutral-400 hover:text-white transition-colors">Laser Matrix</a>
        <a href="/gemstone-prices" class="text-neutral-400 hover:text-white transition-colors">Gems</a>
        <a href="/filaments" class="text-neutral-400 hover:text-white transition-colors">Filamenty</a>
      </nav>
    </div>
    <div class="flex items-center gap-3">
      <img src="<%= user.photo %>" class="w-7 h-7 rounded-full" alt="" />
      <span class="text-sm text-neutral-400"><%= user.name %></span>
      <a href="/logout" class="text-xs text-red-400 hover:text-red-300 transition-colors">Logout</a>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-6 py-8">

    <!-- Header + period selector -->
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl font-semibold text-white">Analytics</h2>
      <div class="flex gap-2 text-sm">
        <% [7, 30, 90].forEach(function(d) { %>
          <a href="/analytics?days=<%= d %>"
             class="px-3 py-1.5 rounded-lg border transition-colors <%= days == d ? 'bg-emerald-900 border-emerald-600 text-emerald-300' : 'border-white/10 text-neutral-400 hover:text-white hover:border-white/20' %>">
            <%= d %>d
          </a>
        <% }); %>
      </div>
    </div>

    <!-- KPI Cards -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      <div class="bg-neutral-900 border border-white/10 rounded-xl px-5 py-4">
        <p class="text-xs text-neutral-500 uppercase tracking-wider mb-1">Dziś — Odwiedziny</p>
        <p class="text-3xl font-bold text-emerald-400"><%= kpi.visitors_today || 0 %></p>
        <p class="text-xs text-neutral-500 mt-1"><%= kpi.visitors_week || 0 %> ten tydzień</p>
      </div>
      <div class="bg-neutral-900 border border-white/10 rounded-xl px-5 py-4">
        <p class="text-xs text-neutral-500 uppercase tracking-wider mb-1">30d — Odwiedziny</p>
        <p class="text-3xl font-bold text-white"><%= kpi.visitors_month || 0 %></p>
        <p class="text-xs text-neutral-500 mt-1"><%= kpi.pageviews_month || 0 %> pageviews</p>
      </div>
      <div class="bg-neutral-900 border border-white/10 rounded-xl px-5 py-4">
        <p class="text-xs text-neutral-500 uppercase tracking-wider mb-1">Dziś — Pageviews</p>
        <p class="text-3xl font-bold text-blue-400"><%= kpi.pageviews_today || 0 %></p>
      </div>
      <div class="bg-neutral-900 border border-white/10 rounded-xl px-5 py-4">
        <p class="text-xs text-neutral-500 uppercase tracking-wider mb-1">Zapytania (30d)</p>
        <p class="text-3xl font-bold text-amber-400"><%= kpi.inquiries_month || 0 %></p>
        <p class="text-xs text-neutral-500 mt-1"><%= kpi.inquiries_total || 0 %> łącznie</p>
      </div>
    </div>

    <!-- Daily chart + Funnel -->
    <div class="grid lg:grid-cols-3 gap-6 mb-8">

      <!-- Daily visitors chart -->
      <div class="lg:col-span-2 bg-neutral-900 border border-white/10 rounded-xl p-5">
        <h3 class="text-sm font-semibold text-white mb-4">Odwiedziny dziennie (<%= days %>d)</h3>
        <% if (daily && daily.length > 0) { %>
          <% var maxV = Math.max.apply(null, daily.map(function(d){ return parseInt(d.visitors) || 0; })) || 1; %>
          <div class="flex items-end gap-1 h-32">
            <% daily.forEach(function(d) { %>
              <% var h = Math.max(4, Math.round((parseInt(d.visitors) / maxV) * 100)); %>
              <div class="flex-1 flex flex-col items-center gap-1 group">
                <div class="relative w-full">
                  <div class="w-full bg-emerald-500/80 rounded-t hover:bg-emerald-400 transition-colors cursor-default"
                       style="height: <%= h %>px;"
                       title="<%= d.day %>: <%= d.visitors %> odwiedzin, <%= d.pageviews %> pageviews"></div>
                </div>
              </div>
            <% }); %>
          </div>
          <div class="flex justify-between mt-2 text-xs text-neutral-600">
            <span><%= daily[0] ? daily[0].day : '' %></span>
            <span><%= daily[daily.length-1] ? daily[daily.length-1].day : '' %></span>
          </div>
        <% } else { %>
          <div class="h-32 flex items-center justify-center text-neutral-600 text-sm">Brak danych</div>
        <% } %>
      </div>

      <!-- Calculator funnel -->
      <div class="bg-neutral-900 border border-white/10 rounded-xl p-5">
        <h3 class="text-sm font-semibold text-white mb-4">Lejek kalkulatora (<%= days %>d)</h3>
        <% var funnelSteps = [
          { label: 'Wejścia na stronę', value: parseInt(calcFunnel.calc_page_visits) || 0, color: 'bg-blue-500' },
          { label: 'Interakcje z kalk.', value: parseInt(calcFunnel.calc_interactions) || 0, color: 'bg-emerald-500' },
          { label: 'Wysłane zapytania', value: parseInt(calcFunnel.inquiry_submits) || 0, color: 'bg-amber-500' },
          { label: 'Leady (z sesją)', value: parseInt(calcFunnel.leads_with_session) || 0, color: 'bg-rose-500' },
        ]; %>
        <% var topFunnel = funnelSteps[0].value || 1; %>
        <div class="space-y-3">
          <% funnelSteps.forEach(function(step, i) { %>
            <div>
              <div class="flex justify-between text-xs mb-1">
                <span class="text-neutral-400"><%= step.label %></span>
                <span class="text-white font-medium"><%= step.value %></span>
              </div>
              <div class="h-2 bg-neutral-800 rounded-full overflow-hidden">
                <div class="h-full <%= step.color %> rounded-full transition-all"
                     style="width: <%= Math.round(step.value / topFunnel * 100) %>%"></div>
              </div>
              <% if (i > 0 && funnelSteps[i-1].value > 0) { %>
                <p class="text-xs text-neutral-600 mt-0.5"><%= Math.round(step.value / funnelSteps[i-1].value * 100) %>% z poprzedniego</p>
              <% } %>
            </div>
          <% }); %>
        </div>
      </div>
    </div>

    <!-- Top pages + Countries + Devices -->
    <div class="grid lg:grid-cols-3 gap-6 mb-8">

      <!-- Top pages -->
      <div class="lg:col-span-2 bg-neutral-900 border border-white/10 rounded-xl p-5">
        <h3 class="text-sm font-semibold text-white mb-4">Top strony (<%= days %>d)</h3>
        <% if (topPages && topPages.length > 0) { %>
          <% var maxPV = parseInt(topPages[0].visitors) || 1; %>
          <div class="space-y-2">
            <% topPages.forEach(function(page) { %>
              <div class="flex items-center gap-3">
                <div class="flex-1 min-w-0">
                  <div class="flex justify-between text-xs mb-1">
                    <span class="text-neutral-300 truncate font-mono"><%= page.path %></span>
                    <span class="text-neutral-400 ml-2 shrink-0"><%= page.visitors %> / <%= page.views %></span>
                  </div>
                  <div class="h-1.5 bg-neutral-800 rounded-full overflow-hidden">
                    <div class="h-full bg-blue-500 rounded-full" style="width:<%= Math.round(parseInt(page.visitors)/maxPV*100) %>%"></div>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
          <p class="text-xs text-neutral-600 mt-3">Odwiedziny / pageviews</p>
        <% } else { %>
          <p class="text-neutral-600 text-sm">Brak danych</p>
        <% } %>
      </div>

      <!-- Countries + Devices -->
      <div class="space-y-6">
        <div class="bg-neutral-900 border border-white/10 rounded-xl p-5">
          <h3 class="text-sm font-semibold text-white mb-3">Kraje (<%= days %>d)</h3>
          <% if (countries && countries.length > 0) { %>
            <div class="space-y-2">
              <% var maxC = parseInt(countries[0].visitors) || 1; %>
              <% countries.forEach(function(c) { %>
                <div class="flex items-center gap-2 text-xs">
                  <span class="text-neutral-300 w-8 font-mono"><%= c.country || '?' %></span>
                  <div class="flex-1 h-1.5 bg-neutral-800 rounded-full overflow-hidden">
                    <div class="h-full bg-emerald-500 rounded-full" style="width:<%= Math.round(parseInt(c.visitors)/maxC*100) %>%"></div>
                  </div>
                  <span class="text-neutral-400 w-6 text-right"><%= c.visitors %></span>
                </div>
              <% }); %>
            </div>
          <% } else { %>
            <p class="text-neutral-600 text-xs">Brak danych</p>
          <% } %>
        </div>

        <div class="bg-neutral-900 border border-white/10 rounded-xl p-5">
          <h3 class="text-sm font-semibold text-white mb-3">Urządzenia (<%= days %>d)</h3>
          <% if (devices && devices.length > 0) { %>
            <% var totalDev = devices.reduce(function(s,d){ return s + parseInt(d.visitors); }, 0) || 1; %>
            <div class="space-y-2">
              <% devices.forEach(function(d) { %>
                <div class="flex items-center justify-between text-xs">
                  <span class="text-neutral-300 capitalize"><%= d.device %></span>
                  <div class="flex items-center gap-2">
                    <span class="text-neutral-400"><%= d.visitors %></span>
                    <span class="text-neutral-600"><%= Math.round(parseInt(d.visitors)/totalDev*100) %>%</span>
                  </div>
                </div>
              <% }); %>
            </div>
          <% } else { %>
            <p class="text-neutral-600 text-xs">Brak danych</p>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Top calculator interactions -->
    <% if (topCalc && topCalc.length > 0) { %>
    <section class="mb-8">
      <div class="bg-neutral-900 border border-white/10 rounded-xl p-5">
        <h3 class="text-sm font-semibold text-white mb-4">Kalkulator — top wybory (<%= days %>d)</h3>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-xs text-neutral-500 uppercase tracking-wider border-b border-white/10">
                <th class="pb-2 text-left">Akcja</th>
                <th class="pb-2 text-left">Wybór</th>
                <th class="pb-2 text-right">Ile razy</th>
              </tr>
            </thead>
            <tbody>
              <% topCalc.forEach(function(row) { %>
              <tr class="border-b border-white/5">
                <td class="py-2 text-neutral-400 font-mono text-xs"><%= row.action %></td>
                <td class="py-2 text-neutral-200"><%= row.label || '—' %></td>
                <td class="py-2 text-right text-amber-400 font-medium"><%= row.cnt %></td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </section>
    <% } %>

    <!-- Recent raw events -->
    <section>
      <div class="bg-neutral-900 border border-white/10 rounded-xl p-5">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-sm font-semibold text-white">Ostatnie zdarzenia</h3>
          <div class="flex items-center gap-2">
            <form method="POST" action="/events/bulk-delete" onsubmit="return confirmBulkDeleteEvents(this)">
              <div class="flex items-center gap-1.5">
                <select name="older_than_days" class="bg-neutral-800 border border-white/10 text-neutral-400 text-xs rounded px-2 py-1">
                  <option value="3">starsze niż 3d</option>
                  <option value="7">starsze niż 7d</option>
                  <option value="30" selected>starsze niż 30d</option>
                  <option value="90">starsze niż 90d</option>
                  <option value="all">⚠ wyczyść wszystko</option>
                </select>
                <button type="submit" class="px-2 py-1 bg-red-950 border border-red-900/50 text-red-400 hover:text-red-300 text-xs rounded transition-colors">Usuń</button>
              </div>
            </form>
          </div>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-xs font-mono">
            <thead>
              <tr class="text-neutral-500 uppercase tracking-wider border-b border-white/10">
                <th class="pb-2 text-left pr-4">Czas</th>
                <th class="pb-2 text-left pr-4">Sesja</th>
                <th class="pb-2 text-left pr-4">Strona</th>
                <th class="pb-2 text-left pr-4">Kat.</th>
                <th class="pb-2 text-left pr-4">Akcja</th>
                <th class="pb-2 text-left pr-4">Label</th>
                <th class="pb-2 text-left pr-4">Kraj</th>
                <th class="pb-2"></th>
              </tr>
            </thead>
            <tbody>
              <% if (recentEvents && recentEvents.length > 0) { %>
                <% recentEvents.forEach(function(e) { %>
                <tr class="border-b border-white/5 hover:bg-white/[0.02] group">
                  <td class="py-1.5 pr-4 text-neutral-500 whitespace-nowrap"><%= fmtDate(e.ts) %></td>
                  <td class="py-1.5 pr-4 text-neutral-500"><%= String(e.session).slice(0,8) %></td>
                  <td class="py-1.5 pr-4 text-neutral-300 max-w-[150px] truncate"><%= e.path || '—' %></td>
                  <td class="py-1.5 pr-4">
                    <span class="px-1.5 py-0.5 rounded text-xs <%= e.category === 'page' ? 'bg-blue-950 text-blue-300' : e.category === 'calc' ? 'bg-amber-950 text-amber-300' : e.category === 'inquiry' ? 'bg-emerald-950 text-emerald-300' : e.category === 'cta' ? 'bg-purple-950 text-purple-300' : e.category === 'funnel' ? 'bg-teal-950 text-teal-300' : 'bg-neutral-800 text-neutral-400' %>">
                      <%= e.category %>
                    </span>
                  </td>
                  <td class="py-1.5 pr-4 text-neutral-400"><%= e.action || '—' %></td>
                  <td class="py-1.5 pr-4 text-neutral-500 max-w-[120px] truncate"><%= e.label || '—' %></td>
                  <td class="py-1.5 pr-4 text-neutral-500"><%= e.country || '—' %></td>
                  <td class="py-1.5 text-right">
                    <form method="POST" action="/events/<%= e.id %>/delete?days=<%= days %>">
                      <button type="submit" class="opacity-0 group-hover:opacity-100 text-red-500 hover:text-red-400 transition-all px-1" title="Usuń">✕</button>
                    </form>
                  </td>
                </tr>
                <% }); %>
              <% } else { %>
              <tr><td colspan="8" class="py-8 text-center text-neutral-600">Brak zdarzeń — dane pojawią się po pierwszych wizytach.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </section>

  </main>
  <script>
    function confirmBulkDeleteEvents(form) {
      const val = form.querySelector('[name="older_than_days"]').value;
      if (val === 'all') return confirm('UWAGA: Usunąć WSZYSTKIE zdarzenia analityczne?\n\nTej operacji nie można cofnąć.');
      return confirm('Usunąć zdarzenia starsze niż ' + val + ' dni?');
    }
  </script>
</body>
</html>
